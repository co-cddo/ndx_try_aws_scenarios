    </tr>
    <tr class="govuk-table__row">
      <th scope="row" class="govuk-table__header">Database</th>
      <td class="govuk-table__cell">Aurora single instance</td>
      <td class="govuk-table__cell">Aurora multi-AZ with read replicas</td>
    </tr>
    <tr class="govuk-table__row">
      <th scope="row" class="govuk-table__header">Containers</th>
      <td class="govuk-table__cell">3 Fargate tasks</td>
      <td class="govuk-table__cell">Auto-scaling based on traffic</td>
    </tr>
    <tr class="govuk-table__row">
      <th scope="row" class="govuk-table__header">Email</th>
      <td class="govuk-table__cell">Disabled in sandbox</td>
      <td class="govuk-table__cell">Amazon SES for citizen notifications</td>
    </tr>
    <tr class="govuk-table__row">
      <th scope="row" class="govuk-table__header">Monitoring</th>
      <td class="govuk-table__cell">CloudWatch Logs</td>
