<details class="govuk-details govuk-!-margin-top-6">
  <summary class="govuk-details__summary">
    <span class="govuk-details__summary-text">
      Troubleshooting: App not loading
    </span>
  </summary>
  <div class="govuk-details__text">
    <p class="govuk-body">If the app doesn't load:</p>
    <ul class="govuk-list govuk-list--bullet">
      <li>Wait 2-3 minutes after stack completion - CloudFront needs time to propagate</li>
      <li>Clear your browser cache or try an incognito window</li>
      <li>Check the CloudFormation "Events" tab for any errors</li>
      <li>Verify the AppUrl is correct from the Outputs tab</li>
    </ul>
  </div>
</details>

<details class="govuk-details">
  <summary class="govuk-details__summary">
    <span class="govuk-details__summary-text">
      Troubleshooting: Login not working
    </span>
  </summary>
  <div class="govuk-details__text">
    <p class="govuk-body">If you can't log in:</p>
    <ul class="govuk-list govuk-list--bullet">
      <li>Copy the password carefully from the Outputs tab - it includes special characters</li>
      <li>The username is <code>admin</code> (lowercase)</li>
    </ul>
  </div>
</details>

