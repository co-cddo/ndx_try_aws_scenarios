    </tr>
    <tr class="govuk-table__row">
      <th scope="row" class="govuk-table__header">Integrations</th>
      <td class="govuk-table__cell">GOV.UK Pay only</td>
      <td class="govuk-table__cell">Council Tax system, NNDR, housing, general ledger</td>
    </tr>
  </tbody>
</table>

