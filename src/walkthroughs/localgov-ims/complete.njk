    </tr>
    <tr class="govuk-table__row">
      <th scope="row" class="govuk-table__header">Database</th>
      <td class="govuk-table__cell">SQL Server Express (RDS)</td>
      <td class="govuk-table__cell">SQL Server Standard or Enterprise with Multi-AZ</td>
    </tr>
    <tr class="govuk-table__row">
