{
  "_meta": {
    "category": "Greetings & Social",
    "description": "Common BSL greeting and social interaction signs",
    "sources": [
      "BSL SignBank (UCL)",
      "Access BSL",
      "Evergreen Life BSL guide",
      "british-sign.co.uk",
      "Baby BSL",
      "Sutton-Spence & Woll (1999)"
    ]
  },
  "signs": [
    {
      "gloss": "HELLO",
      "handshape": "B-open",
      "handshapeDescription": "Open hand, fingers spread slightly",
      "location": "side of head",
      "movement": "Single arc wave",
      "movementType": "path_arc",
      "hands": "one",
      "palmOrientation": "palm_away",
      "contactPoint": null,
      "nonManual": "smile, eye contact",
      "notes": "Same sign as GOODBYE - context distinguishes"
    },
    {
      "gloss": "GOODBYE",
      "handshape": "B-open",
      "handshapeDescription": "Open hand, fingers spread slightly",
      "location": "side of head",
      "movement": "Waving arc motion",
      "movementType": "path_arc",
      "hands": "one",
      "palmOrientation": "palm_away",
      "contactPoint": null,
      "nonManual": "smile",
      "notes": "Same manual form as HELLO"
    },
    {
      "gloss": "PLEASE",
      "handshape": "B",
      "handshapeDescription": "Flat hand, fingers together",
      "location": "chin/lips",
      "movement": "Fingertips touch lips then move hand forward and down",
      "movementType": "path_forward_down",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "fingertips to lips",
      "nonManual": "polite expression",
      "notes": "Same sign as THANK-YOU in many regions"
    },
    {
      "gloss": "THANK-YOU",
      "handshape": "B",
      "handshapeDescription": "Flat hand, fingers together",
      "location": "chin/lips",
      "movement": "Fingertips touch chin then move hand forward and down",
      "movementType": "path_forward_down",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "fingertips to chin",
      "nonManual": "smile, slight head nod",
      "notes": "Same sign as PLEASE in many regions; mouthing distinguishes"
    },
    {
      "gloss": "SORRY",
      "handshape": "A",
      "handshapeDescription": "Closed fist",
      "location": "chest",
      "movement": "Circular rubbing motion on chest",
      "movementType": "circular",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "fist on chest",
      "nonManual": "apologetic expression, furrowed brow",
      "notes": null
    },
    {
      "gloss": "EXCUSE-ME",
      "handshape": "B",
      "handshapeDescription": "Flat hand",
      "location": "non-dominant forearm",
      "movement": "Dominant hand brushes along non-dominant forearm",
      "movementType": "path_along",
      "hands": "two",
      "palmOrientation": "palm_down",
      "contactPoint": "fingertips brush forearm",
      "nonManual": "apologetic/polite expression",
      "notes": null
    },
    {
      "gloss": "WELCOME",
      "handshape": "B-open",
      "handshapeDescription": "Open flat hand",
      "location": "neutral space",
      "movement": "Hand sweeps inward toward body in arc",
      "movementType": "path_arc_toward",
      "hands": "one",
      "palmOrientation": "palm_up",
      "contactPoint": null,
      "nonManual": "smile, welcoming expression",
      "notes": null
    },
    {
      "gloss": "NICE-TO-MEET-YOU",
      "handshape": "G",
      "handshapeDescription": "Index finger extended",
      "location": "neutral space",
      "movement": "Two index fingers approach each other from sides and meet",
      "movementType": "path_converging",
      "hands": "two",
      "palmOrientation": "palm_down",
      "contactPoint": "fingertips meet",
      "nonManual": "smile",
      "notes": "Compound: NICE + MEET; or MEET sign with pleased expression"
    },
    {
      "gloss": "HOW-ARE-YOU",
      "handshape": "Thumb",
      "handshapeDescription": "Closed fist with thumbs up",
      "location": "chest",
      "movement": "Both thumbs-up hands on chest then move forward",
      "movementType": "path_forward",
      "hands": "two",
      "palmOrientation": "palm_toward then palm_away",
      "contactPoint": "thumbs on chest initially",
      "nonManual": "raised eyebrows (yes/no question), questioning expression, eye contact",
      "notes": "Eyebrow raise is grammatically required for yes/no question"
    },
    {
      "gloss": "FINE",
      "handshape": "Thumb",
      "handshapeDescription": "Thumbs up",
      "location": "chest",
      "movement": "Thumb taps chest once or twice",
      "movementType": "contact_tap",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": "thumb to chest",
      "nonManual": "slight smile, head nod",
      "notes": null
    },
    {
      "gloss": "GOOD",
      "handshape": "Thumb",
      "handshapeDescription": "Thumbs up from fist",
      "location": "chin",
      "movement": "Thumb touches chin and moves forward",
      "movementType": "path_forward",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": "thumb to chin",
      "nonManual": "positive expression, head nod",
      "notes": "Thumb = positive meaning in BSL"
    },
    {
      "gloss": "GOOD-MORNING",
      "handshape": "Thumb + B-bent",
      "handshapeDescription": "Compound: GOOD (thumb) then MORNING (bent hand)",
      "location": "chin then chest",
      "movement": "GOOD sign then bent hand touches one side of chest then moves to other side",
      "movementType": "compound",
      "hands": "one",
      "palmOrientation": "varies",
      "contactPoint": "thumb to chin, then hand to chest",
      "nonManual": "smile, mouth 'good morning'",
      "notes": "Compound sign: GOOD + MORNING"
    },
    {
      "gloss": "GOOD-AFTERNOON",
      "handshape": "Thumb + B",
      "handshapeDescription": "Compound: GOOD then AFTERNOON",
      "location": "chin then neutral space",
      "movement": "GOOD sign, then flat hand arcs forward-down from shoulder height",
      "movementType": "compound",
      "hands": "one",
      "palmOrientation": "varies",
      "contactPoint": "thumb to chin",
      "nonManual": "smile, mouth 'good afternoon'",
      "notes": "Compound: GOOD + AFTERNOON"
    },
    {
      "gloss": "GOOD-EVENING",
      "handshape": "Thumb + B-bent",
      "handshapeDescription": "Compound: GOOD then EVENING",
      "location": "chin then nose level",
      "movement": "GOOD sign, then bent hand arcs downward from nose area",
      "movementType": "compound",
      "hands": "one",
      "palmOrientation": "varies",
      "contactPoint": "thumb to chin",
      "nonManual": "smile, mouth 'good evening'",
      "notes": "Compound: GOOD + EVENING"
    },
    {
      "gloss": "GOOD-NIGHT",
      "handshape": "Thumb + B",
      "handshapeDescription": "Compound: GOOD then NIGHT",
      "location": "chin then down",
      "movement": "GOOD sign, then flat hand moves downward",
      "movementType": "compound",
      "hands": "one",
      "palmOrientation": "varies",
      "contactPoint": "thumb to chin",
      "nonManual": "smile, mouth 'good night'",
      "notes": "Compound: GOOD + NIGHT"
    },
    {
      "gloss": "SEE-YOU-LATER",
      "handshape": "V",
      "handshapeDescription": "Index and middle fingers extended, spread",
      "location": "eye then forward",
      "movement": "V-hand at eyes then points forward",
      "movementType": "path_forward",
      "hands": "one",
      "palmOrientation": "palm_toward then palm_away",
      "contactPoint": "V-fingers near eyes",
      "nonManual": "smile, mouth 'see you later'",
      "notes": "Compound: SEE + LATER"
    },
    {
      "gloss": "CONGRATULATIONS",
      "handshape": "B-open",
      "handshapeDescription": "Open hands, fingers spread",
      "location": "neutral space, above head level",
      "movement": "Both hands shake/wave in air above head",
      "movementType": "local_hand_wave",
      "hands": "two",
      "palmOrientation": "palm_away",
      "contactPoint": null,
      "nonManual": "big smile, excited expression",
      "notes": "Celebratory gesture; can use finger wiggle"
    },
    {
      "gloss": "WELL-DONE",
      "handshape": "B",
      "handshapeDescription": "Flat hands",
      "location": "neutral space",
      "movement": "Clapping motion (hands come together repeatedly)",
      "movementType": "path_converging_repeated",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "contactPoint": "palms clap",
      "nonManual": "smile, approving expression",
      "notes": null
    },
    {
      "gloss": "TAKE-CARE",
      "handshape": "A",
      "handshapeDescription": "Fists",
      "location": "neutral space",
      "movement": "One fist on top of the other, gentle rocking motion",
      "movementType": "local_rock",
      "hands": "two",
      "palmOrientation": "palm_down",
      "contactPoint": "fist on fist",
      "nonManual": "caring expression, mouth 'take care'",
      "notes": null
    },
    {
      "gloss": "YES",
      "handshape": "A",
      "handshapeDescription": "Fist",
      "location": "neutral space",
      "movement": "Fist nods forward (wrist bend) like nodding head",
      "movementType": "local_wrist_nod",
      "hands": "one",
      "palmOrientation": "palm_away",
      "contactPoint": null,
      "nonManual": "head nod",
      "notes": "Head nod alone can also mean YES"
    },
    {
      "gloss": "NO",
      "handshape": "G + N",
      "handshapeDescription": "Index finger then index+middle together",
      "location": "neutral space",
      "movement": "Index and middle fingers close together onto thumb (like closing)",
      "movementType": "local_finger_close",
      "hands": "one",
      "palmOrientation": "palm_away",
      "contactPoint": "fingers tap thumb",
      "nonManual": "head shake, negative expression",
      "notes": "Head shake alone can negate; several regional variants exist"
    }
  ]
}
