  "signs": [
    {"gloss": "SUN", "handshape": "5", "location": "above head, to side", "movement": "Open spread hand held above and to side, fingers wiggle (rays shining)", "movementType": "local_finger_wiggle", "hands": "one", "palmOrientation": "palm_down", "nonManual": "squinting as if in bright light, mouth 'sun'"},
    {"gloss": "RAIN", "handshape": "5", "location": "above head moving down", "movement": "Both open hands at eye level move downward, fingers wiggle (raindrops falling)", "movementType": "path_down_wiggle", "hands": "two", "palmOrientation": "palm_down", "nonManual": "mouth 'rain'", "notes": "Size/speed of movement can show intensity: light drizzle vs heavy rain"},
    {"gloss": "SNOW", "handshape": "5", "location": "above head moving down", "movement": "Both open hands move down slowly with gentle finger wiggle (snowflakes drifting)", "movementType": "path_down_slow_wiggle", "hands": "two", "palmOrientation": "palm_down", "nonManual": "mouth 'snow'", "notes": "Slower and gentler than RAIN"},
    {"gloss": "WIND", "handshape": "5 or B", "location": "neutral space", "movement": "Both open hands sweep sideways together (wind blowing)", "movementType": "path_sideways", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "puffing cheeks, mouth 'wind'", "notes": "Direction of movement shows wind direction; cheek puff shows strength"},
    {"gloss": "CLOUD", "handshape": "5-claw", "location": "above head", "movement": "Both claw hands trace cloud shape above head, palms outward", "movementType": "path_outline_arc", "hands": "two", "palmOrientation": "palm_away", "nonManual": "mouth 'cloud'"},
    {"gloss": "STORM", "handshape": "5-claw", "location": "neutral space, wide", "movement": "Claw hands make aggressive circular motions (violent weather)", "movementType": "circular_fast", "hands": "two", "palmOrientation": "varies", "nonManual": "intense expression, puffed cheeks, mouth 'storm'"},
    {"gloss": "THUNDER", "handshape": "G + A", "location": "ear then neutral space", "movement": "Points to ear then both fists shake/vibrate (rumbling)", "movementType": "local_shake", "hands": "two", "palmOrientation": "varies", "nonManual": "startled expression, mouth 'thunder'"},
    {"gloss": "LIGHTNING", "handshape": "G", "location": "above, moving down", "movement": "Index finger zigzags downward sharply (lightning bolt)", "movementType": "path_zigzag_down", "hands": "one", "palmOrientation": "palm_away", "nonManual": "wide eyes, sharp expression, mouth 'lightning'"},
    {"gloss": "FOG", "handshape": "5", "location": "in front of face", "movement": "Both open hands move slowly across in front of face (obscuring vision)", "movementType": "path_across_slow", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "squinting, mouth 'fog'"},
    {"gloss": "ICE", "handshape": "5-claw", "location": "neutral space", "movement": "Claw hands held rigid, tense (frozen stiff)", "movementType": "hold_tense", "hands": "two", "palmOrientation": "palm_down", "nonManual": "tense face, shiver, mouth 'ice'"},
    {"gloss": "RAINBOW", "handshape": "4 or 5", "location": "above, wide arc", "movement": "Spread hand traces a wide arc above (rainbow arc)", "movementType": "path_arc_wide", "hands": "one", "palmOrientation": "palm_away", "nonManual": "amazed expression, mouth 'rainbow'"},
    {"gloss": "WEATHER", "handshape": "E or 5-claw", "location": "neutral space", "movement": "Both hands with bent fingers twist back and forth (changing conditions)", "movementType": "local_hand_rotation_twist_repeated", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "mouth 'weather'"},
    {"gloss": "SPRING", "handshape": "O to 5", "location": "non-dominant palm", "movement": "Closed hand on palm opens upward (flower blooming/growing)", "movementType": "path_up_open", "hands": "two", "palmOrientation": "non-dominant palm_up", "nonManual": "mouth 'spring'"},
    {"gloss": "SUMMER", "handshape": "G", "location": "forehead", "movement": "Index finger wipes across forehead (wiping sweat)", "movementType": "path_across", "hands": "one", "palmOrientation": "palm_down", "contactPoint": "finger across forehead", "nonManual": "squinting, wiping brow, mouth 'summer'"},
    {"gloss": "AUTUMN", "handshape": "5", "location": "shoulder level", "movement": "Open hand drifts downward with gentle swaying (leaves falling)", "movementType": "path_down_swaying", "hands": "one", "palmOrientation": "palm_down", "nonManual": "mouth 'autumn'"},
    {"gloss": "WINTER", "handshape": "A", "location": "shoulders", "movement": "Fists at shoulders, body shivers (cold)", "movementType": "local_shake", "hands": "two", "palmOrientation": "palm_toward", "contactPoint": "fists near shoulders", "nonManual": "shivering, mouth 'winter'", "notes": "Related to COLD"},
    {"gloss": "TREE", "handshape": "5 + B", "location": "non-dominant flat hand (ground), dominant forearm vertical with spread fingers (branches)", "movement": "Non-dominant flat hand horizontal (ground), dominant elbow on non-dominant hand, forearm vertical with spread fingers swaying (branches in wind)", "movementType": "local_sway", "hands": "two", "palmOrientation": "varies", "nonManual": "mouth 'tree'", "notes": "Iconic: trunk on ground with branches"},
    {"gloss": "FLOWER", "handshape": "O", "location": "cheek, both sides", "movement": "O-hand (closed petals) taps one side of nose/cheek then other side", "movementType": "contact_tap_alternating", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "fingertips at cheek", "nonManual": "pleasant expression, mouth 'flower'"},
    {"gloss": "RIVER", "handshape": "B or 5", "location": "neutral space", "movement": "Open hand makes winding path forward (flowing water)", "movementType": "path_forward_winding", "hands": "one", "palmOrientation": "palm_down", "nonManual": "mouth 'river'"},
    {"gloss": "SEA", "handshape": "5", "location": "neutral space, wide", "movement": "Both open hands make rolling wave motion", "movementType": "path_wave", "hands": "two", "palmOrientation": "palm_down", "nonManual": "mouth 'sea'"},
    {"gloss": "MOUNTAIN", "handshape": "B", "location": "neutral space", "movement": "Both flat hands trace steep triangular peak shape upward", "movementType": "path_up_peak", "hands": "two", "palmOrientation": "palms facing each other", "nonManual": "mouth 'mountain'", "notes": "Height of peak shows mountain size"},
    {"gloss": "SKY", "handshape": "B", "location": "above head", "movement": "Flat hand sweeps across above head (expanse of sky)", "movementType": "path_across_wide", "hands": "one", "palmOrientation": "palm_down", "nonManual": "eyes look up, mouth 'sky'"},
    {"gloss": "MOON", "handshape": "C", "location": "above, to side", "movement": "C-hand held up (crescent moon shape)", "movementType": "hold", "hands": "one", "palmOrientation": "palm_away", "nonManual": "mouth 'moon'"},
    {"gloss": "STAR", "handshape": "G", "location": "above head", "movement": "Index fingers alternately flick upward (twinkling)", "movementType": "local_flick_alternating", "hands": "two", "palmOrientation": "palm_away", "nonManual": "eyes look up, mouth 'star'"},
    {"gloss": "FIRE", "handshape": "5", "location": "neutral space, low", "movement": "Both open hands with fingers wiggling rise upward (flames)", "movementType": "path_up_wiggle", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "mouth 'fire'", "notes": "Iconic: flickering flames rising"}
  ]
