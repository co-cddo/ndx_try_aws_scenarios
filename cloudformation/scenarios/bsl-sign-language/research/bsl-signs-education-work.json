{
  "_meta": {
    "category": "Education & Work",
    "description": "BSL signs for education, work, technology vocabulary",
    "sources": ["Access BSL", "SignBSL GCSE vocabulary", "BSL SignBank"]
  },
  "signs": [
    {"gloss": "SCHOOL", "handshape": "B", "location": "mouth", "movement": "Flat hand waves side to side in front of mouth", "movementType": "path_sideways_repeated", "hands": "one", "palmOrientation": "palm_away", "nonManual": "mouth 'school'"},
    {"gloss": "COLLEGE", "handshape": "C-fingerspell", "location": "neutral space", "movement": "C-handshape or fingerspell", "movementType": "hold", "hands": "two", "palmOrientation": "varies", "nonManual": "mouth 'college'"},
    {"gloss": "UNIVERSITY", "handshape": "U-fingerspell", "location": "neutral space", "movement": "U-handshape", "movementType": "hold", "hands": "two", "palmOrientation": "varies", "nonManual": "mouth 'uni' or 'university'"},
    {"gloss": "CLASS", "handshape": "C", "location": "neutral space", "movement": "C-hands trace a group shape (circle of people)", "movementType": "circular", "hands": "two", "palmOrientation": "palms facing each other", "nonManual": "mouth 'class'"},
    {"gloss": "LESSON", "handshape": "B", "location": "non-dominant palm", "movement": "Dominant flat hand taps non-dominant palm (like opening pages)", "movementType": "contact_tap_repeated", "hands": "two", "palmOrientation": "non-dominant palm_up", "nonManual": "mouth 'lesson'"},
    {"gloss": "TEACHER", "handshape": "G", "location": "sides of head", "movement": "Both index fingers raise up beside head", "movementType": "path_up", "hands": "two", "palmOrientation": "palm_away", "nonManual": "mouth 'teacher'"},
    {"gloss": "STUDENT", "handshape": "5 to O-flat", "location": "neutral space to forehead", "movement": "Open hands close while moving toward forehead (gathering knowledge)", "movementType": "path_toward_close", "hands": "two", "palmOrientation": "palm_up then toward", "nonManual": "mouth 'student'"},
    {"gloss": "STUDY", "handshape": "V", "location": "non-dominant palm (book)", "movement": "V-hand (eyes) moves back and forth over non-dominant palm (reading/studying)", "movementType": "path_back_and_forth", "hands": "two", "palmOrientation": "V palm_down, non-dominant palm_up", "nonManual": "focused expression, mouth 'study'"},
    {"gloss": "LEARN", "handshape": "5 to O-flat", "location": "neutral space to forehead", "movement": "Open palms close fingers toward thumbs while moving toward forehead", "movementType": "path_toward_close", "hands": "two", "palmOrientation": "palm_up then toward", "nonManual": "attentive expression, mouth 'learn'"},
    {"gloss": "EXAM", "handshape": "G + B", "location": "non-dominant palm", "movement": "Dominant index finger writes/marks on non-dominant palm (marking exam)", "movementType": "path_zigzag", "hands": "two", "palmOrientation": "non-dominant palm_up", "nonManual": "mouth 'exam'"},
    {"gloss": "TEST", "handshape": "G + B", "location": "non-dominant palm", "movement": "Similar to EXAM, index marks on palm", "movementType": "path_zigzag", "hands": "two", "palmOrientation": "non-dominant palm_up", "nonManual": "mouth 'test'"},
    {"gloss": "PASS", "handshape": "B", "location": "non-dominant hand", "movement": "Dominant hand sweeps over non-dominant hand successfully", "movementType": "path_over", "hands": "two", "palmOrientation": "varies", "nonManual": "positive expression, smile, mouth 'pass'"},
    {"gloss": "FAIL", "handshape": "B", "location": "non-dominant hand", "movement": "Dominant hand hits against non-dominant hand and falls away", "movementType": "path_down_contact", "hands": "two", "palmOrientation": "varies", "nonManual": "disappointed expression, mouth 'fail'"},
    {"gloss": "HOMEWORK", "handshape": "compound", "location": "varies", "movement": "HOME sign + WORK sign in sequence", "movementType": "compound", "hands": "varies", "palmOrientation": "varies", "nonManual": "mouth 'homework'"},
    {"gloss": "BOOK", "handshape": "B", "location": "neutral space", "movement": "Palms together then open outward like opening a book", "movementType": "path_apart_hinge", "hands": "two", "palmOrientation": "palms together then palm_up", "contactPoint": "palms together at start", "nonManual": "mouth 'book'"},
    {"gloss": "PEN", "handshape": "G-closed + B", "location": "non-dominant palm", "movement": "Dominant hand mimics holding pen and writing on non-dominant palm", "movementType": "path_zigzag", "hands": "two", "palmOrientation": "non-dominant palm_up", "nonManual": "mouth 'pen'"},
    {"gloss": "PAPER", "handshape": "B", "location": "neutral space", "movement": "Both flat hands held flat, parallel, one slides off the other", "movementType": "path_forward", "hands": "two", "palmOrientation": "palm_down", "nonManual": "mouth 'paper'"},
    {"gloss": "COMPUTER", "handshape": "C or O-flat", "location": "neutral space", "movement": "C-handshape or typing motion on imaginary keyboard", "movementType": "local_finger_flex or hold", "hands": "two", "palmOrientation": "palm_down", "nonManual": "mouth 'computer'"},
    {"gloss": "INTERNET", "handshape": "5-claw", "location": "neutral space", "movement": "Claw hands interlink and rotate (networked connections)", "movementType": "circular_interlinked", "hands": "two", "palmOrientation": "palm_toward each other", "nonManual": "mouth 'internet'"},
    {"gloss": "EMAIL", "handshape": "E-fingerspell + path", "location": "neutral space", "movement": "E-handshape or @ sign traced, then forward sending motion", "movementType": "path_forward", "hands": "one or two", "palmOrientation": "varies", "nonManual": "mouth 'email'"},
    {"gloss": "PHONE", "handshape": "Y", "location": "ear to mouth", "movement": "Y-hand (thumb at ear, little finger at mouth) held at side of face", "movementType": "hold", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "thumb at ear, pinky at mouth", "nonManual": "mouth 'phone'", "notes": "Iconic: holding phone receiver"},
    {"gloss": "MEETING", "handshape": "B or 5", "location": "neutral space", "movement": "Both flat hands come together from sides (people meeting)", "movementType": "path_together", "hands": "two", "palmOrientation": "palms facing each other", "contactPoint": "fingertips meet", "nonManual": "mouth 'meeting'"},
    {"gloss": "BOSS", "handshape": "B or Thumb", "location": "shoulder", "movement": "Thumb or flat hand taps shoulder (epaulette/authority)", "movementType": "contact_tap", "hands": "one", "palmOrientation": "varies", "contactPoint": "hand on shoulder", "nonManual": "mouth 'boss'"},
    {"gloss": "JOB", "handshape": "A", "location": "neutral space", "movement": "One fist taps on the other (same as WORK)", "movementType": "contact_tap_repeated", "hands": "two", "palmOrientation": "palm_down", "nonManual": "mouth 'job'"},
    {"gloss": "MONEY", "handshape": "O-flat + B", "location": "non-dominant palm", "movement": "Dominant pinched fingers tap non-dominant palm (counting coins)", "movementType": "contact_tap_repeated", "hands": "two", "palmOrientation": "non-dominant palm_up", "contactPoint": "fingertips on palm", "nonManual": "mouth 'money'"},
    {"gloss": "IDEA", "handshape": "G", "location": "temple", "movement": "Index finger at temple flicks upward and away (lightbulb moment)", "movementType": "path_up_flick", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "finger at temple", "nonManual": "brightened expression, mouth 'idea'"},
    {"gloss": "PROBLEM", "handshape": "V-bent", "location": "forehead", "movement": "Bent V-fingers tap forehead (troubled thinking)", "movementType": "contact_tap", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "bent fingers on forehead", "nonManual": "worried expression, mouth 'problem'"},
    {"gloss": "QUESTION", "handshape": "G-bent", "location": "neutral space", "movement": "Bent index traces question mark shape in the air", "movementType": "path_question_mark", "hands": "one", "palmOrientation": "palm_away", "nonManual": "raised eyebrows, mouth 'question'"},
    {"gloss": "ANSWER", "handshape": "G", "location": "mouth then forward", "movement": "Index finger from mouth moves forward decisively (answer coming out)", "movementType": "path_forward", "hands": "one", "palmOrientation": "palm_left", "contactPoint": "from mouth", "nonManual": "mouth 'answer'"},
    {"gloss": "EXPLAIN", "handshape": "B", "location": "neutral space", "movement": "Both flat hands alternate moving forward (laying out information)", "movementType": "path_forward_alternating", "hands": "two", "palmOrientation": "palm_up", "nonManual": "mouth 'explain'"},
    {"gloss": "PRACTICE", "handshape": "A + B", "location": "non-dominant palm", "movement": "Dominant fist rubs back and forth on non-dominant palm (repetitive action)", "movementType": "path_back_and_forth", "hands": "two", "palmOrientation": "non-dominant palm_up", "contactPoint": "fist on palm", "nonManual": "mouth 'practice'"},
    {"gloss": "IMPROVE", "handshape": "B", "location": "non-dominant arm", "movement": "Dominant hand hops upward along non-dominant arm (steps of improvement)", "movementType": "path_up_steps", "hands": "two", "palmOrientation": "varies", "contactPoint": "hand on arm", "nonManual": "positive expression, mouth 'improve'"}
  ]
}
