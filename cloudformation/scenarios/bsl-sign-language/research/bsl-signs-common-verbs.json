    {
      "gloss": "GO",
      "handshape": "B",
      "handshapeDescription": "Flat right hand, palm facing left",
      "location": "beside flat non-dominant hand, neutral space",
      "movement": "Flat hand moves forward with slight arc",
      "movementType": "path_forward_arc",
      "hands": "two",
      "palmOrientation": "palm_left (dominant), palm_right (non-dominant)",
      "contactPoint": "starts beside non-dominant hand",
      "nonManual": "mouth 'go'",
      "notes": "Agreement verb: direction of movement can change to show destination"
    },
    {
      "gloss": "COME",
      "handshape": "G",
      "handshapeDescription": "Index finger extended, or flat hand",
      "location": "neutral space",
      "movement": "Hand/finger moves toward signer (beckoning)",
      "movementType": "path_toward",
      "hands": "one",
      "palmOrientation": "palm_up",
      "contactPoint": null,
      "nonManual": "mouth 'come'",
      "notes": "Agreement verb: direction shows source"
    },
