  "_meta": {
    "category": "Common Verbs",
    "description": "BSL signs for frequently used verbs",
    "sources": ["BSL SignBank", "Evergreen Life", "SignBSL", "BSL Corpus Project", "Sutton-Spence & Woll (1999)"],
    "notes": "BSL has three verb types: plain verbs (no spatial modification), agreement/indicating verbs (direction shows subject/object), and spatial verbs (show location/movement)"
  },
