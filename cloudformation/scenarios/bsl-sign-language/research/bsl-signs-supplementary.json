    {"gloss": "TOUCH", "handshape": "8 or G", "location": "back of non-dominant hand", "movement": "Middle finger or index taps back of non-dominant hand", "movementType": "contact_tap", "hands": "two", "palmOrientation": "non-dominant palm_down", "contactPoint": "finger taps back of hand", "nonManual": "mouth 'touch'"},
