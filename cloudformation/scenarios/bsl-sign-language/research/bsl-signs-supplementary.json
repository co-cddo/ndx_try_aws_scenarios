    {"gloss": "TROUSERS", "handshape": "B", "location": "hips/legs", "movement": "Both hands pat down from hips along thighs (trouser legs)", "movementType": "path_down", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "mouth 'trousers'"},
    {"gloss": "SHOES", "handshape": "A", "location": "neutral space, low", "movement": "Two fists tap together side by side (shoe heels clicking)", "movementType": "contact_tap_repeated", "hands": "two", "palmOrientation": "palm_down", "nonManual": "mouth 'shoes'"},
    {"gloss": "HAT", "handshape": "A or B", "location": "head", "movement": "Both hands mime placing hat on top of head, pull downward", "movementType": "path_down", "hands": "two", "palmOrientation": "palm_down", "contactPoint": "above head", "nonManual": "mouth 'hat'"},
    {"gloss": "COAT", "handshape": "A", "location": "shoulders", "movement": "Fists at lapels pull forward and down (putting on coat)", "movementType": "path_down_forward", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "mouth 'coat'"},
    {"gloss": "GLASSES", "handshape": "G-closed", "location": "eyes", "movement": "Thumb and index of each hand trace glasses frames around eyes", "movementType": "path_outline", "hands": "two", "palmOrientation": "palm_toward", "contactPoint": "beside eyes", "nonManual": "mouth 'glasses'"},
    {"gloss": "WATCH-timepiece", "handshape": "G", "location": "wrist", "movement": "Index finger taps non-dominant wrist", "movementType": "contact_tap", "hands": "two", "palmOrientation": "varies", "contactPoint": "finger on wrist", "nonManual": "mouth 'watch'"},
    {"gloss": "TABLE", "handshape": "B", "location": "neutral space", "movement": "Both flat hands palms down move apart (flat surface)", "movementType": "path_apart", "hands": "two", "palmOrientation": "palm_down", "nonManual": "mouth 'table'"},
    {"gloss": "CHAIR", "handshape": "N-bent + N", "location": "neutral space", "movement": "Dominant bent-N (legs/sitting) sits on non-dominant N-hand (chair surface)", "movementType": "contact_sit", "hands": "two", "palmOrientation": "varies", "nonManual": "mouth 'chair'"},
    {"gloss": "BED", "handshape": "B", "location": "side of head", "movement": "Both flat hands together at side of head (pillow), head tilts", "movementType": "hold_tilt", "hands": "two", "palmOrientation": "palms together", "contactPoint": "hands as pillow", "nonManual": "head tilt, eyes close, mouth 'bed'"},
    {"gloss": "TELEVISION", "handshape": "T-fingerspell + V", "location": "neutral space", "movement": "T-V fingerspelled or box shape traced with index fingers", "movementType": "path_rectangle", "hands": "two", "palmOrientation": "palm_away", "nonManual": "mouth 'TV'"},
