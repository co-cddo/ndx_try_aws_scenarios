  "signs": [
    {"gloss": "CLOTHES", "handshape": "5", "location": "chest", "movement": "Both open hands brush down chest (indicating clothing on body)", "movementType": "path_down", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "mouth 'clothes'"},
