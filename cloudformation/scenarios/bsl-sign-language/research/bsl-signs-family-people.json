{
  "_meta": {
    "category": "Family & People",
    "description": "BSL signs for family members and people",
    "sources": ["Access BSL", "BSL SignBank", "Commanding Hands", "Sutton-Spence & Woll (1999)"]
  },
  "signs": [
    {
      "gloss": "MOTHER",
      "handshape": "M-fist",
      "handshapeDescription": "M-handshape (three fingers over thumb) on dominant hand",
      "location": "palm of non-dominant hand",
      "movement": "M-hand taps palm of flat non-dominant hand twice",
      "movementType": "contact_tap_repeated",
      "hands": "two",
      "palmOrientation": "dominant palm_down, non-dominant palm_up",
      "contactPoint": "M-fist taps open palm",
      "nonManual": "mouth 'mother' or 'mummy'",
      "notes": "Alternative: M-hand taps temple on dominant side"
    },
    {
      "gloss": "FATHER",
      "handshape": "N",
      "handshapeDescription": "Index and middle fingers extended together",
      "location": "non-dominant hand fingers",
      "movement": "Dominant N-hand taps against corresponding fingers of non-dominant N-hand twice",
      "movementType": "contact_tap_repeated",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "contactPoint": "extended fingers tap",
      "nonManual": "mouth 'father' or 'daddy'",
      "notes": null
    },
    {
      "gloss": "SISTER",
      "handshape": "G-bent",
      "handshapeDescription": "Hooked/bent index finger, other fingers closed",
      "location": "nose",
      "movement": "Hooked index finger taps nose twice",
      "movementType": "contact_tap_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "bent finger to nose",
      "nonManual": "mouth 'sister'",
      "notes": null
    },
    {
      "gloss": "BROTHER",
      "handshape": "A",
      "handshapeDescription": "Two closed fists",
      "location": "neutral space, in front of body",
      "movement": "Two fists rub up and down against each other",
      "movementType": "path_back_and_forth",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "contactPoint": "fists rub together",
      "nonManual": "mouth 'brother'",
      "notes": null
    },
    {
      "gloss": "SON",
      "handshape": "G",
      "handshapeDescription": "Extended index finger",
      "location": "chin",
      "movement": "Index finger slides across chin",
      "movementType": "path_sideways",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "finger across chin",
      "nonManual": "mouth 'son' or 'boy'",
      "notes": "Related to BOY sign (chin = male gender marker area)"
    },
    {
      "gloss": "DAUGHTER",
      "handshape": "D-fingerspell",
      "handshapeDescription": "D from two-handed fingerspelling alphabet",
      "location": "neutral space",
      "movement": "Static fingerspell D shape",
      "movementType": "hold",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": "fingers form D shape",
      "nonManual": "mouth 'daughter'",
      "notes": "Often fingerspelled or uses initialized sign"
    },
    {
      "gloss": "BABY",
      "handshape": "B",
      "handshapeDescription": "Flat hands / arms crossed",
      "location": "neutral space, waist level",
      "movement": "Arms cradle and rock side to side as if holding a baby",
      "movementType": "local_rock",
      "hands": "two",
      "palmOrientation": "palm_up",
      "contactPoint": "arms crossed",
      "nonManual": "gentle expression, mouth 'baby'",
      "notes": "Iconic: rocking a baby"
    },
    {
      "gloss": "CHILD",
      "handshape": "B-bent",
      "handshapeDescription": "Bent flat hand, palm down",
      "location": "neutral space, waist height",
      "movement": "Hand held low, palm down, may pat downward (indicating small height)",
      "movementType": "path_down",
      "hands": "one",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'child'",
      "notes": "Height indicates child's stature"
    },
    {
      "gloss": "CHILDREN",
      "handshape": "B-open",
      "handshapeDescription": "Open flat hands, palms down",
      "location": "neutral space, waist height",
      "movement": "Both hands pat downward at different heights",
      "movementType": "path_down_alternating",
      "hands": "two",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'children'",
      "notes": "Plural of CHILD; multiple pats at different positions"
    },
    {
      "gloss": "GRANDMOTHER",
      "handshape": "fingerspell",
      "handshapeDescription": "G then M fingerspelled",
      "location": "neutral space",
      "movement": "Sequential fingerspelling G-M (or G-R-A-N)",
      "movementType": "sequential",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": null,
      "nonManual": "mouth 'grandmother' or 'grandma'",
      "notes": "Often abbreviated fingerspelling; some regions have lexicalized signs"
    },
    {
      "gloss": "GRANDFATHER",
      "handshape": "fingerspell",
      "handshapeDescription": "G then F (or G then D for grandad) fingerspelled",
      "location": "neutral space",
      "movement": "Sequential fingerspelling",
      "movementType": "sequential",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": null,
      "nonManual": "mouth 'grandfather' or 'grandad'",
      "notes": "Often abbreviated fingerspelling"
    },
    {
      "gloss": "AUNT",
      "handshape": "N-bent",
      "handshapeDescription": "Index and middle fingers extended together and bent at middle joint",
      "location": "chin",
      "movement": "Bent fingers tap chin twice",
      "movementType": "contact_tap_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "bent fingers to chin",
      "nonManual": "mouth 'aunt'",
      "notes": "Same manual sign as UNCLE - mouthing distinguishes"
    },
    {
      "gloss": "UNCLE",
      "handshape": "N-bent",
      "handshapeDescription": "Index and middle fingers extended together and bent",
      "location": "chin",
      "movement": "Bent fingers tap chin twice",
      "movementType": "contact_tap_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "bent fingers to chin",
      "nonManual": "mouth 'uncle'",
      "notes": "Same manual sign as AUNT - mouthing distinguishes"
    },
    {
      "gloss": "COUSIN",
      "handshape": "C",
      "handshapeDescription": "C-shape hand, curved fingers and thumb",
      "location": "opposite shoulder",
      "movement": "C-hand taps opposite shoulder twice",
      "movementType": "contact_tap_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "C-hand to shoulder",
      "nonManual": "mouth 'cousin'",
      "notes": null
    },
    {
      "gloss": "NEPHEW",
      "handshape": "N-bent",
      "handshapeDescription": "Index and middle fingers extended together and bent",
      "location": "chin",
      "movement": "Bent fingers tap chin twice",
      "movementType": "contact_tap_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "bent fingers to chin",
      "nonManual": "mouth 'nephew'",
      "notes": "Same manual form as AUNT/UNCLE/NIECE - distinguished by mouthing"
    },
    {
      "gloss": "NIECE",
      "handshape": "N-bent",
      "handshapeDescription": "Index and middle fingers extended together and bent",
      "location": "chin",
      "movement": "Bent fingers tap chin twice",
      "movementType": "contact_tap_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "bent fingers to chin",
      "nonManual": "mouth 'niece'",
      "notes": "Same manual form as AUNT/UNCLE/NEPHEW - distinguished by mouthing"
    },
    {
      "gloss": "HUSBAND",
      "handshape": "A",
      "handshapeDescription": "Closed fists",
      "location": "neutral space",
      "movement": "Two fists come together, interlock or clasp (like clasped hands)",
      "movementType": "path_converging",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "contactPoint": "hands clasp",
      "nonManual": "mouth 'husband'",
      "notes": "Same base sign as WIFE/MARRIED; mouthing distinguishes"
    },
    {
      "gloss": "WIFE",
      "handshape": "A",
      "handshapeDescription": "Closed fists",
      "location": "neutral space",
      "movement": "Two fists come together and clasp",
      "movementType": "path_converging",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "contactPoint": "hands clasp",
      "nonManual": "mouth 'wife'",
      "notes": "Same base as HUSBAND/MARRIED; mouthing distinguishes"
    },
    {
      "gloss": "PARTNER",
      "handshape": "B",
      "handshapeDescription": "Flat hands",
      "location": "neutral space",
      "movement": "Two flat hands held side by side, move forward together",
      "movementType": "path_forward",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "contactPoint": "hands side by side",
      "nonManual": "mouth 'partner'",
      "notes": null
    },
    {
      "gloss": "FRIEND",
      "handshape": "B",
      "handshapeDescription": "Two flat hands",
      "location": "neutral space",
      "movement": "Hands clasp together and shake up and down twice (handshake motion)",
      "movementType": "path_up_down_repeated",
      "hands": "two",
      "palmOrientation": "palms toward each other",
      "contactPoint": "hands clasp",
      "nonManual": "smile, mouth 'friend'",
      "notes": "Iconic: handshake"
    },
    {
      "gloss": "MAN",
      "handshape": "B",
      "handshapeDescription": "Flat hand or fist",
      "location": "chin",
      "movement": "Hand strokes chin downward (like stroking a beard)",
      "movementType": "path_down",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "fingers/thumb to chin",
      "nonManual": "mouth 'man'",
      "notes": "Chin area = male gender marker in BSL (beard area)"
    },
    {
      "gloss": "WOMAN",
      "handshape": "B",
      "handshapeDescription": "Flat hand",
      "location": "cheek",
      "movement": "Fingertips stroke cheek downward",
      "movementType": "path_down",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "fingertips to cheek",
      "nonManual": "mouth 'woman'",
      "notes": "Cheek area used for female-associated signs in some variants"
    },
    {
      "gloss": "BOY",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "chin",
      "movement": "Index finger strokes across chin",
      "movementType": "path_sideways",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "finger across chin",
      "nonManual": "mouth 'boy'",
      "notes": "Same as SON in many dialects"
    },
    {
      "gloss": "GIRL",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "cheek",
      "movement": "Index finger strokes down cheek",
      "movementType": "path_down",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "finger on cheek",
      "nonManual": "mouth 'girl'",
      "notes": null
    },
    {
      "gloss": "PERSON",
      "handshape": "B",
      "handshapeDescription": "Flat hands",
      "location": "neutral space",
      "movement": "Both flat hands trace outline of body (head to shoulders down)",
      "movementType": "path_down",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "contactPoint": null,
      "nonManual": "mouth 'person'",
      "notes": null
    },
    {
      "gloss": "PEOPLE",
      "handshape": "V",
      "handshapeDescription": "V-hands (index and middle extended)",
      "location": "neutral space",
      "movement": "V-hands move in alternating circles (like legs walking)",
      "movementType": "circular_alternating",
      "hands": "two",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'people'",
      "notes": "Iconic: many people moving around"
    },
    {
      "gloss": "FAMILY",
      "handshape": "B-open",
      "handshapeDescription": "Open hand or F-handshape",
      "location": "neutral space, in front of body",
      "movement": "Hand traces small clockwise circles",
      "movementType": "circular",
      "hands": "one",
      "palmOrientation": "palm_away",
      "contactPoint": null,
      "nonManual": "mouth 'family'",
      "notes": "Circle represents the family unit"
    },
    {
      "gloss": "PARENTS",
      "handshape": "compound",
      "handshapeDescription": "MOTHER + FATHER compound or initialized P",
      "location": "varies",
      "movement": "Sign MOTHER then FATHER in quick succession",
      "movementType": "compound",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": "varies",
      "nonManual": "mouth 'parents'",
      "notes": "Compound of MOTHER + FATHER"
    },
    {
      "gloss": "NEIGHBOUR",
      "handshape": "B",
      "handshapeDescription": "Flat hands",
      "location": "neutral space",
      "movement": "Two flat hands side by side, one moves slightly away then back (next-door concept)",
      "movementType": "path_sideways",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "contactPoint": null,
      "nonManual": "mouth 'neighbour'",
      "notes": "Iconic: houses next to each other"
    },
    {
      "gloss": "TWINS",
      "handshape": "G",
      "handshapeDescription": "Index fingers extended",
      "location": "neutral space",
      "movement": "Two index fingers held parallel, move down together",
      "movementType": "path_down",
      "hands": "two",
      "palmOrientation": "palm_away",
      "contactPoint": null,
      "nonManual": "mouth 'twins'",
      "notes": "Two parallel fingers = two same-age people"
    }
  ]
}
