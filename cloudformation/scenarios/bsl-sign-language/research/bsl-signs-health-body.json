{
  "_meta": {
    "category": "Health & Body",
    "description": "BSL signs for body parts, health conditions, and medical vocabulary",
    "sources": ["BSL SignBank", "SignBSL", "Access BSL"]
  },
  "signs": [
    {"gloss": "HEAD", "handshape": "B", "location": "head", "movement": "Flat hand taps top of head", "movementType": "contact_tap", "hands": "one", "palmOrientation": "palm_down", "nonManual": "mouth 'head'"},
    {"gloss": "FACE", "handshape": "G", "location": "face", "movement": "Index finger circles around face", "movementType": "circular", "hands": "one", "palmOrientation": "palm_toward", "nonManual": "mouth 'face'"},
    {"gloss": "EYE", "handshape": "G", "location": "eye", "movement": "Index finger points to eye", "movementType": "contact_point", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "finger near eye", "nonManual": "mouth 'eye'"},
    {"gloss": "EAR", "handshape": "G", "location": "ear", "movement": "Index finger points to ear", "movementType": "contact_point", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "finger near ear", "nonManual": "mouth 'ear'"},
    {"gloss": "NOSE", "handshape": "G", "location": "nose", "movement": "Index finger points to nose", "movementType": "contact_point", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "finger on nose", "nonManual": "mouth 'nose'"},
    {"gloss": "MOUTH", "handshape": "G", "location": "mouth", "movement": "Index finger circles around mouth area", "movementType": "circular", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "near mouth", "nonManual": "mouth 'mouth'"},
    {"gloss": "TEETH", "handshape": "G", "location": "mouth", "movement": "Index finger taps teeth or runs along teeth", "movementType": "contact_tap", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "finger on teeth", "nonManual": "show teeth, mouth 'teeth'"},
    {"gloss": "HAIR", "handshape": "O-flat", "location": "head, side", "movement": "Pinched fingers pull down from head (like pulling strand of hair)", "movementType": "path_down", "hands": "one", "palmOrientation": "varies", "contactPoint": "fingers at hair", "nonManual": "mouth 'hair'"},
    {"gloss": "NECK", "handshape": "C", "location": "neck", "movement": "C-hand wraps around front of neck", "movementType": "contact_wrap", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "hand on neck", "nonManual": "mouth 'neck'"},
    {"gloss": "SHOULDER", "handshape": "B", "location": "shoulder", "movement": "Flat hand taps opposite shoulder", "movementType": "contact_tap", "hands": "one", "palmOrientation": "palm_down", "contactPoint": "hand on shoulder", "nonManual": "mouth 'shoulder'"},
    {"gloss": "ARM", "handshape": "B", "location": "arm", "movement": "Flat hand runs along arm from shoulder to wrist", "movementType": "path_down_along", "hands": "two", "palmOrientation": "dominant palm_down", "contactPoint": "hand on arm", "nonManual": "mouth 'arm'"},
    {"gloss": "HAND", "handshape": "B", "location": "hand", "movement": "One flat hand indicates the other hand", "movementType": "contact_point", "hands": "two", "palmOrientation": "non-dominant palm_up", "contactPoint": "hand indicates hand", "nonManual": "mouth 'hand'"},
    {"gloss": "FINGER", "handshape": "G", "location": "finger", "movement": "Dominant hand grasps/points to non-dominant finger", "movementType": "contact_grasp", "hands": "two", "palmOrientation": "varies", "contactPoint": "touching finger", "nonManual": "mouth 'finger'"},
    {"gloss": "LEG", "handshape": "B", "location": "thigh", "movement": "Flat hand pats thigh", "movementType": "contact_tap", "hands": "one", "palmOrientation": "palm_down", "contactPoint": "hand on thigh", "nonManual": "mouth 'leg'"},
    {"gloss": "FOOT", "handshape": "B", "location": "foot/ankle", "movement": "Flat hand points to or touches foot area", "movementType": "contact_point", "hands": "one", "palmOrientation": "palm_down", "contactPoint": "toward foot", "nonManual": "mouth 'foot'"},
    {"gloss": "BACK-body", "handshape": "B", "location": "back/shoulder", "movement": "Hand reaches over shoulder to pat back", "movementType": "contact_tap", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "hand on back", "nonManual": "mouth 'back'"},
    {"gloss": "STOMACH", "handshape": "B", "location": "stomach", "movement": "Flat hand pats stomach", "movementType": "contact_tap", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "hand on stomach", "nonManual": "mouth 'stomach'"},
    {"gloss": "HEART", "handshape": "G or 8", "location": "left chest", "movement": "Middle finger or index finger taps left chest where heart is", "movementType": "contact_tap", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "finger on chest", "nonManual": "mouth 'heart'"},
    {
      "gloss": "PAIN",
      "handshape": "G",
      "handshapeDescription": "Index fingers",
      "location": "location of pain",
      "movement": "Both index fingers point at each other near pain location, twist/turn (stabbing pain)",
      "movementType": "local_hand_rotation_twist",
      "hands": "two",
      "palmOrientation": "palm_down",
      "nonManual": "pained expression, wincing",
      "notes": "Location of sign moves to where the pain is"
    },
    {
      "gloss": "HEADACHE",
      "handshape": "G",
      "handshapeDescription": "Index fingers pointing at each other",
      "location": "temples (sides of head)",
      "movement": "Index fingers at temples twist/press inward",
      "movementType": "local_hand_rotation_twist",
      "hands": "two",
      "palmOrientation": "palm_down",
      "nonManual": "pained expression, squinted eyes",
      "notes": "PAIN sign located at head"
    },
    {
      "gloss": "ILL",
      "handshape": "I",
      "handshapeDescription": "Little fingers extended (both hands)",
      "location": "chest",
      "movement": "Little fingers touch chest then drop downward",
      "movementType": "path_down",
      "hands": "two",
      "palmOrientation": "palm_toward",
      "contactPoint": "little fingers on chest",
      "nonManual": "unwell expression, drooped",
      "notes": "Little finger = negative; at chest = affecting body"
    },
    {
      "gloss": "SICK",
      "handshape": "I",
      "handshapeDescription": "Little finger extended",
      "location": "chest",
      "movement": "Little finger on chest, short downward movement, repeated",
      "movementType": "path_down_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "little finger on chest",
      "nonManual": "sick expression"
    },
    {
      "gloss": "HEALTHY",
      "handshape": "Thumb",
      "handshapeDescription": "Thumbs up (both hands)",
      "location": "chest",
      "movement": "Both thumbs-up hands on chest, move forward with positive motion",
      "movementType": "path_forward",
      "hands": "two",
      "palmOrientation": "palm_toward",
      "contactPoint": "thumbs on chest",
      "nonManual": "bright healthy expression, smile"
    },
    {
      "gloss": "MEDICINE",
      "handshape": "G-closed + B",
      "handshapeDescription": "Pinch hand on palm (grinding medicine)",
      "location": "non-dominant palm",
      "movement": "Dominant pinch hand circles/grinds on non-dominant palm (mortar and pestle)",
      "movementType": "circular",
      "hands": "two",
      "palmOrientation": "non-dominant palm_up",
      "contactPoint": "pinch on palm",
      "nonManual": "mouth 'medicine'"
    },
    {
      "gloss": "DOCTOR",
      "handshape": "N",
      "handshapeDescription": "Two fingers (stethoscope/pulse)",
      "location": "wrist",
      "movement": "Two fingers tap wrist (taking pulse)",
      "movementType": "contact_tap",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": "fingers on wrist pulse point",
      "nonManual": "mouth 'doctor'"
    },
    {
      "gloss": "NURSE",
      "handshape": "N",
      "handshapeDescription": "Two fingers",
      "location": "wrist",
      "movement": "Similar to DOCTOR but with 'nurse' mouthing; or N-fingerspell",
      "movementType": "contact_tap",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": "fingers on wrist",
      "nonManual": "mouth 'nurse'"
    },
    {
      "gloss": "DEAF",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "ear then mouth",
      "movement": "Index finger touches ear then touches near mouth (can't hear, can't speak)",
      "movementType": "path_ear_to_mouth",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "finger at ear, then at mouth",
      "nonManual": "mouth 'deaf'"
    },
    {
      "gloss": "HEARING",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "mouth",
      "movement": "Index finger at mouth moves forward in small circles (speaking)",
      "movementType": "circular",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": "finger near mouth",
      "nonManual": "mouth 'hearing'"
    },
    {
      "gloss": "AMBULANCE",
      "handshape": "5-claw",
      "handshapeDescription": "Claw hand (siren flashing)",
      "location": "top of head",
      "movement": "Claw hand on top of head opens and closes (flashing lights)",
      "movementType": "local_finger_flex",
      "hands": "one",
      "palmOrientation": "palm_down",
      "contactPoint": "on top of head",
      "nonManual": "urgent expression, mouth 'ambulance'"
    },
    {
      "gloss": "INJECTION",
      "handshape": "L or Thumb",
      "handshapeDescription": "Thumb pushes down (syringe plunger)",
      "location": "upper arm",
      "movement": "Hand mimics jabbing needle into upper arm, thumb pushes down (plunger)",
      "movementType": "contact_press_down",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "on upper arm",
      "nonManual": "wincing, mouth 'injection'"
    },
    {
      "gloss": "TEMPERATURE",
      "handshape": "G",
      "handshapeDescription": "Index finger (thermometer)",
      "location": "mouth",
      "movement": "Index finger held at mouth like thermometer",
      "movementType": "hold",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": "finger at mouth",
      "nonManual": "mouth 'temperature'"
    },
    {
      "gloss": "COUGH",
      "handshape": "A",
      "handshapeDescription": "Fist",
      "location": "chest",
      "movement": "Fist thumps chest (coughing motion)",
      "movementType": "contact_tap_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "fist on chest",
      "nonManual": "coughing mouth pattern, body jolts"
    }
  ]
