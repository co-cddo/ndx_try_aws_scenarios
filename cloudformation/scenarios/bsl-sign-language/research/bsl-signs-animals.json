{
  "_meta": {
    "category": "Animals",
    "description": "BSL signs for common animals",
    "sources": ["Access BSL", "Baby BSL", "BSL SignBank", "Let's Sign BSL"],
    "notes": "Many animal signs are iconic - they mimic a distinctive feature of the animal (whiskers, ears, trunk, etc.)"
  },
  "signs": [
    {"gloss": "CAT", "handshape": "O-flat or G-closed", "location": "cheek/mouth", "movement": "Pinched fingers at side of mouth pull outward (whiskers)", "movementType": "path_outward_repeated", "hands": "one or two", "palmOrientation": "palm_toward", "contactPoint": "fingers at cheek", "nonManual": "mouth 'cat'", "notes": "Iconic: cat whiskers"},
    {"gloss": "DOG", "handshape": "B", "location": "thigh/leg", "movement": "Flat hand pats thigh twice (calling a dog)", "movementType": "contact_tap_repeated", "hands": "one", "palmOrientation": "palm_down", "contactPoint": "hand pats thigh", "nonManual": "mouth 'dog'", "notes": "Iconic: patting leg to call dog"},
    {"gloss": "BIRD", "handshape": "G-closed", "location": "mouth", "movement": "Thumb and index finger snap together at mouth (beak opening and closing)", "movementType": "local_finger_flex", "hands": "one", "palmOrientation": "palm_left", "contactPoint": "near mouth", "nonManual": "mouth 'bird'", "notes": "Iconic: bird beak"},
    {"gloss": "FISH", "handshape": "B", "location": "neutral space", "movement": "Flat hand held horizontally wiggles forward (fish swimming)", "movementType": "path_forward_wiggle", "hands": "one", "palmOrientation": "palm_down", "nonManual": "mouth 'fish'"},
    {"gloss": "HORSE", "handshape": "N-bent or A", "location": "head or neutral space", "movement": "Bent fingers at head bounce forward (trotting), or fists alternately rise and fall (galloping)", "movementType": "path_forward_bouncing", "hands": "two", "palmOrientation": "varies", "nonManual": "mouth 'horse'", "notes": "Three regional variants exist"},
    {"gloss": "COW", "handshape": "Horns", "location": "forehead", "movement": "Horns handshape (index + little finger) at forehead, twist outward", "movementType": "local_hand_rotation_twist", "hands": "one", "palmOrientation": "palm_away", "contactPoint": "thumb on forehead", "nonManual": "mouth 'cow'", "notes": "Iconic: cow horns"},
    {"gloss": "SHEEP", "handshape": "V-bent + B", "location": "non-dominant forearm", "movement": "Bent V-fingers (scissors/shears) move along non-dominant forearm (shearing wool)", "movementType": "path_along_open_close", "hands": "two", "palmOrientation": "varies", "contactPoint": "fingers on forearm", "nonManual": "mouth 'sheep'", "notes": "Iconic: shearing wool"},
    {"gloss": "PIG", "handshape": "B", "location": "nose/chin", "movement": "Flat hand under nose/chin bends fingers (snout rooting)", "movementType": "local_finger_flex", "hands": "one", "palmOrientation": "palm_down", "contactPoint": "under nose", "nonManual": "scrunched nose, mouth 'pig'"},
    {"gloss": "RABBIT", "handshape": "N", "location": "head", "movement": "Both N-hands at top of head, fingers bend up and down (ears twitching)", "movementType": "local_finger_flex", "hands": "two", "palmOrientation": "palm_away", "contactPoint": "hands on top of head", "nonManual": "mouth 'rabbit'", "notes": "Iconic: long ears twitching"},
    {"gloss": "MOUSE", "handshape": "G", "location": "nose", "movement": "Index finger rubs/twitches at tip of nose (mouse whiskers/nose)", "movementType": "local_twist", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "finger on nose tip", "nonManual": "twitching nose, mouth 'mouse'"},
    {"gloss": "CHICKEN", "handshape": "G-closed", "location": "mouth", "movement": "Pinch hand opens and closes at mouth (pecking)", "movementType": "local_finger_flex", "hands": "one", "palmOrientation": "palm_down", "contactPoint": "near mouth", "nonManual": "mouth 'chicken'"},
    {"gloss": "DUCK", "handshape": "G-closed", "location": "mouth", "movement": "Flat open-close hand at mouth (wider bill than chicken), may add waddle", "movementType": "local_finger_flex", "hands": "one", "palmOrientation": "palm_down", "contactPoint": "at mouth", "nonManual": "mouth 'duck'", "notes": "Wider opening than CHICKEN to show bill"},
    {"gloss": "SNAKE", "handshape": "V-bent or G", "location": "neutral space", "movement": "Hand zigzags forward sinuously (snake slithering)", "movementType": "path_zigzag_forward", "hands": "one", "palmOrientation": "palm_down", "nonManual": "mouth 'snake'", "notes": "Iconic: sinuous slithering movement"},
    {"gloss": "SPIDER", "handshape": "5-claw", "location": "neutral space", "movement": "Claw hand crawls forward with finger wiggling (legs moving)", "movementType": "path_forward_wiggle", "hands": "one", "palmOrientation": "palm_down", "nonManual": "mouth 'spider'", "notes": "Iconic: multiple legs crawling"},
    {"gloss": "BEE", "handshape": "G-closed", "location": "cheek or neutral space", "movement": "Pinch at cheek (sting) then hand buzzes away in zigzag", "movementType": "contact_then_zigzag", "hands": "one", "palmOrientation": "varies", "contactPoint": "pinch on cheek", "nonManual": "mouth 'bee', wincing"},
    {"gloss": "BUTTERFLY", "handshape": "Thumb-link + 5", "location": "neutral space", "movement": "Thumbs hooked together, fingers spread and flap (wings)", "movementType": "local_finger_flap", "hands": "two", "palmOrientation": "palm_away", "contactPoint": "thumbs linked", "nonManual": "mouth 'butterfly'", "notes": "Iconic: wings flapping"},
    {"gloss": "ELEPHANT", "handshape": "C to fist", "location": "nose then forward-down", "movement": "C-hand at nose extends forward and sweeps down (trunk)", "movementType": "path_forward_down_arc", "hands": "one", "palmOrientation": "palm_down", "contactPoint": "starts at nose", "nonManual": "mouth 'elephant'", "notes": "Iconic: elephant trunk"},
    {"gloss": "LION", "handshape": "5-claw", "location": "head", "movement": "Claw hands sweep back over head (mane)", "movementType": "path_back_over", "hands": "two", "palmOrientation": "palm_down", "contactPoint": "near forehead", "nonManual": "fierce expression, mouth 'lion'", "notes": "Iconic: lion's mane"},
    {"gloss": "TIGER", "handshape": "5-claw", "location": "face", "movement": "Claw hands at face pull outward (stripes/claws)", "movementType": "path_outward", "hands": "two", "palmOrientation": "palm_toward", "contactPoint": "near face", "nonManual": "fierce expression, mouth 'tiger'"},
    {"gloss": "BEAR", "handshape": "5-claw", "location": "chest, crossed", "movement": "Claw hands crossed on chest, scratch inward (bear scratching/hugging)", "movementType": "local_scratch", "hands": "two", "palmOrientation": "palm_toward", "contactPoint": "hands on chest", "nonManual": "mouth 'bear'"},
    {"gloss": "MONKEY", "handshape": "5-claw", "location": "sides of body", "movement": "Claw hands at sides scratch upward (monkey scratching)", "movementType": "path_up_scratch", "hands": "two", "palmOrientation": "palm_toward", "contactPoint": "hands at sides", "nonManual": "cheeky expression, mouth 'monkey'"},
    {"gloss": "FROG", "handshape": "V to V-bent", "location": "chin", "movement": "V-hand under chin, fingers bend (throat pulsing)", "movementType": "local_finger_flex", "hands": "one", "palmOrientation": "palm_down", "contactPoint": "under chin", "nonManual": "mouth 'frog'"},
    {"gloss": "WHALE", "handshape": "5", "location": "neutral space", "movement": "Large undulating movement forward and up (whale breaching)", "movementType": "path_forward_wave", "hands": "one or two", "palmOrientation": "palm_down", "nonManual": "puffed cheeks (large), mouth 'whale'"},
    {"gloss": "DOLPHIN", "handshape": "B", "location": "neutral space", "movement": "Flat hand dips and rises in waves forward (dolphin leaping through waves)", "movementType": "path_forward_wave_arc", "hands": "one", "palmOrientation": "palm_down", "nonManual": "mouth 'dolphin'"}
  ]
}
