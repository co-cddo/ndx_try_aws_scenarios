{
  "_meta": {
    "category": "Common Adjectives",
    "description": "BSL signs for frequently used adjectives and descriptive words",
    "sources": ["BSL SignBank", "Access BSL", "SignBSL", "University of Surrey BSL", "Sutton-Spence & Woll"],
    "notes": "Facial expression heavily modifies adjective meaning in BSL. Puffed cheeks = intensifier (very big), sucked cheeks = diminisher (very small)"
  },
  "signs": [
    {
      "gloss": "BIG",
      "handshape": "B or 5",
      "handshapeDescription": "Open hands",
      "location": "neutral space",
      "movement": "Both hands start together then move apart widely",
      "movementType": "path_apart",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "nonManual": "puffed cheeks for emphasis, mouth 'big'",
      "notes": "Size of movement indicates degree of bigness"
    },
    {
      "gloss": "SMALL",
      "handshape": "B",
      "handshapeDescription": "Flat hands",
      "location": "neutral space",
      "movement": "Both hands close together, palms facing, small gap between them",
      "movementType": "path_together",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "nonManual": "sucked cheeks, squinted eyes, mouth 'small'",
      "notes": "Gap size shows how small"
    },
    {
      "gloss": "GOOD",
      "handshape": "Thumb",
      "handshapeDescription": "Thumbs up",
      "location": "chin",
      "movement": "Thumb touches chin then moves forward",
      "movementType": "path_forward",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": "thumb to chin",
      "nonManual": "positive expression, nod",
      "notes": "Thumb = positive/good in BSL"
    },
    {
      "gloss": "BAD",
      "handshape": "I",
      "handshapeDescription": "Little finger extended",
      "location": "chin",
      "movement": "Little finger touches chin then moves forward/down",
      "movementType": "path_forward",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": "little finger to chin",
      "nonManual": "negative expression, slight frown",
      "notes": "Little finger = negative/bad in BSL (opposite of thumb)"
    },
    {
      "gloss": "HAPPY",
      "handshape": "B",
      "handshapeDescription": "Flat hands",
      "location": "chest",
      "movement": "Both flat hands brush upward on chest alternately or together (rising joy)",
      "movementType": "path_up_repeated",
      "hands": "two",
      "palmOrientation": "palm_toward",
      "contactPoint": "hands on chest",
      "nonManual": "big smile, bright expression, mouth 'happy'",
      "notes": "Upward movement on chest = positive emotion rising"
    },
    {
      "gloss": "SAD",
      "handshape": "B or 5",
      "handshapeDescription": "Flat or open hand",
      "location": "face",
      "movement": "Hand moves downward past face (tears falling)",
      "movementType": "path_down",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "near face",
      "nonManual": "sad expression, drooped mouth, mouth 'sad'",
      "notes": "Downward = negative emotion"
    },
    {
      "gloss": "ANGRY",
      "handshape": "5-claw",
      "handshapeDescription": "Claw hands",
      "location": "chest/stomach",
      "movement": "Claw hands tense and rise up from stomach to chest (anger rising)",
      "movementType": "path_up_tense",
      "hands": "two",
      "palmOrientation": "palm_toward",
      "contactPoint": null,
      "nonManual": "furrowed brow, tight lips, angry face, mouth 'angry'",
      "notes": "Tense movement = intensity. Facial expression essential."
    },
    {
      "gloss": "SCARED",
      "handshape": "5 or B-open",
      "handshapeDescription": "Open hands",
      "location": "chest",
      "movement": "Hands shake/tremble at chest, body pulls back slightly",
      "movementType": "local_shake",
      "hands": "two",
      "palmOrientation": "palm_toward",
      "contactPoint": null,
      "nonManual": "wide eyes, open mouth, fearful expression",
      "notes": "Trembling = fear"
    },
    {
      "gloss": "TIRED",
      "handshape": "B",
      "handshapeDescription": "Flat hands",
      "location": "chest",
      "movement": "Both flat hands on chest drop/slump downward",
      "movementType": "path_down_slump",
      "hands": "two",
      "palmOrientation": "palm_toward",
      "contactPoint": "fingertips on chest",
      "nonManual": "tired expression, drooped shoulders, heavy eyes, mouth 'tired'",
      "notes": "Body language reinforces meaning"
    },
    {
      "gloss": "HOT",
