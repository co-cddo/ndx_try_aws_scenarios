{
  "_meta": {
    "category": "Time",
    "description": "BSL signs for time concepts, days, months, temporal references",
    "sources": ["BSL SignBank", "University of Surrey BSL", "Access BSL", "SignBSL"]
  },
  "signs": [
    {
      "gloss": "TODAY",
      "handshape": "B",
      "handshapeDescription": "Flat hands",
      "location": "neutral space, body level",
      "movement": "Both flat hands point downward, small double movement down (indicating 'now/here')",
      "movementType": "path_down_repeated",
      "hands": "two",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'today'",
      "notes": "Signs at body = present time"
    },
    {
      "gloss": "TOMORROW",
      "handshape": "Thumb or B",
      "handshapeDescription": "Thumb extended from fist, or flat hand",
      "location": "cheek then forward",
      "movement": "Thumb touches cheek then arcs forward",
      "movementType": "path_arc_forward",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": "thumb on cheek",
      "nonManual": "mouth 'tomorrow'",
      "notes": "Forward movement = future on Timeline A"
    },
    {
      "gloss": "YESTERDAY",
      "handshape": "Thumb or B",
      "handshapeDescription": "Thumb extended from fist",
      "location": "cheek then backward",
      "movement": "Thumb touches cheek then arcs backward over shoulder",
      "movementType": "path_arc_backward",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": "thumb on cheek",
      "nonManual": "mouth 'yesterday'",
      "notes": "Backward movement = past on Timeline A"
    },
    {
      "gloss": "NOW",
      "handshape": "B",
      "handshapeDescription": "Flat hands, palms down",
      "location": "neutral space, directly in front of body",
      "movement": "Both hands press down sharply once",
      "movementType": "path_down_sharp",
      "hands": "two",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'now', emphatic expression",
      "notes": "At body level = present"
    },
    {
      "gloss": "LATER",
      "handshape": "Thumb",
      "handshapeDescription": "Thumb extended",
      "location": "neutral space, forward",
      "movement": "Hand moves forward in small arc",
      "movementType": "path_forward",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": null,
      "nonManual": "mouth 'later'",
      "notes": "Forward = future"
    },
    {
      "gloss": "BEFORE",
      "handshape": "B",
      "handshapeDescription": "Flat hand",
      "location": "neutral space",
      "movement": "Hand moves backward (toward past)",
      "movementType": "path_backward",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": null,
      "nonManual": "mouth 'before'",
      "notes": null
    },
    {
      "gloss": "AFTER",
      "handshape": "B",
      "handshapeDescription": "Flat hand",
      "location": "neutral space",
      "movement": "Hand moves forward (toward future)",
      "movementType": "path_forward",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": null,
      "nonManual": "mouth 'after'",
      "notes": null
    },
    {
      "gloss": "MORNING",
      "handshape": "B-bent",
      "handshapeDescription": "Bent flat hand",
      "location": "chest",
      "movement": "Bent hand touches one side of chest then moves across to other side (sun rising)",
      "movementType": "path_sideways",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "hand on chest",
      "nonManual": "mouth 'morning'",
      "notes": "Iconic: sun rising across horizon"
    },
    {
      "gloss": "AFTERNOON",
      "handshape": "B",
      "handshapeDescription": "Flat hand",
      "location": "shoulder height",
      "movement": "Flat hand arcs downward and forward from shoulder level (sun past zenith)",
      "movementType": "path_arc_down",
      "hands": "one",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'afternoon'",
      "notes": "Iconic: sun descending"
    },
    {
      "gloss": "EVENING",
      "handshape": "B-bent",
      "handshapeDescription": "Bent flat hand",
      "location": "nose level, forward",
      "movement": "Hand arcs downward (sun setting)",
      "movementType": "path_arc_down",
      "hands": "one",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'evening'",
      "notes": "Iconic: sun going below horizon"
    },
    {
      "gloss": "NIGHT",
      "handshape": "B",
      "handshapeDescription": "Flat hands",
      "location": "neutral space",
      "movement": "Both flat hands cross over each other and move downward (darkness covering)",
      "movementType": "path_down_crossing",
      "hands": "two",
      "palmOrientation": "palm_down",
      "contactPoint": "wrists cross",
      "nonManual": "mouth 'night'",
      "notes": "Iconic: darkness falling"
    },
    {
      "gloss": "WEEK",
      "handshape": "G",
      "handshapeDescription": "Index finger extended",
      "location": "non-dominant palm",
      "movement": "Index finger slides across non-dominant palm from heel to fingertips",
      "movementType": "path_forward_along",
      "hands": "two",
      "palmOrientation": "non-dominant palm_up",
      "contactPoint": "finger slides on palm",
      "nonManual": "mouth 'week'",
      "notes": "Timeline B: along the forearm/hand"
    },
    {
      "gloss": "MONTH",
      "handshape": "G",
      "handshapeDescription": "Index finger extended",
      "location": "non-dominant index finger",
      "movement": "Dominant index traces down the length of non-dominant extended index finger",
      "movementType": "path_down_along",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": "finger traces finger",
      "nonManual": "mouth 'month'",
      "notes": null
    },
    {
      "gloss": "YEAR",
      "handshape": "A",
      "handshapeDescription": "Fists",
      "location": "neutral space",
      "movement": "One fist circles around the other in vertical plane (earth around sun)",
      "movementType": "circular_vertical",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": null,
      "nonManual": "mouth 'year'",
      "notes": "Iconic: orbit of earth around sun"
    },
    {
      "gloss": "MONDAY",
      "handshape": "M-fist",
      "handshapeDescription": "M-handshape from fingerspelling",
      "location": "non-dominant palm",
      "movement": "M-hand taps non-dominant palm",
      "movementType": "contact_tap",
      "hands": "two",
      "palmOrientation": "non-dominant palm_up",
      "contactPoint": "M on palm",
      "nonManual": "mouth 'Monday'",
      "notes": "Initialized: M for Monday"
    },
    {
      "gloss": "TUESDAY",
      "handshape": "T-fingerspell",
      "handshapeDescription": "T-handshape from fingerspelling",
      "location": "non-dominant palm or neutral space",
      "movement": "T-handshape presented or taps palm",
      "movementType": "contact_tap",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": null,
      "nonManual": "mouth 'Tuesday'",
      "notes": "Initialized: T for Tuesday"
    },
    {
      "gloss": "WEDNESDAY",
      "handshape": "W-fingerspell",
      "handshapeDescription": "W-handshape (three fingers spread)",
      "location": "non-dominant palm or neutral space",
      "movement": "W-handshape taps or is presented",
      "movementType": "contact_tap",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": null,
      "nonManual": "mouth 'Wednesday'",
      "notes": "Initialized: W for Wednesday"
    },
    {
      "gloss": "THURSDAY",
      "handshape": "T+H fingerspell",
      "handshapeDescription": "TH combination from fingerspelling",
      "location": "neutral space",
      "movement": "TH-handshape presented",
      "movementType": "hold",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": null,
      "nonManual": "mouth 'Thursday'",
      "notes": "Initialized: TH for Thursday"
    },
    {
      "gloss": "FRIDAY",
      "handshape": "F-fingerspell",
      "handshapeDescription": "F-handshape from fingerspelling",
      "location": "neutral space",
      "movement": "F-handshape presented or taps",
      "movementType": "hold",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": null,
      "nonManual": "mouth 'Friday'",
      "notes": "Initialized: F for Friday"
    },
    {
      "gloss": "SATURDAY",
      "handshape": "S-fingerspell",
      "handshapeDescription": "S-handshape",
      "location": "neutral space",
      "movement": "S-handshape presented",
      "movementType": "hold",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": null,
      "nonManual": "mouth 'Saturday'",
      "notes": "Initialized: S; some regions have distinct lexical signs"
    },
    {
      "gloss": "SUNDAY",
      "handshape": "S-fingerspell",
      "handshapeDescription": "S-handshape or specific variant",
      "location": "neutral space",
      "movement": "S-handshape presented, may differ from Saturday variant",
      "movementType": "hold",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": null,
      "nonManual": "mouth 'Sunday'",
      "notes": "Regional variation significant for weekend day names"
    },
    {
      "gloss": "ALWAYS",
      "handshape": "G",
      "handshapeDescription": "Index finger extended",
      "location": "neutral space",
      "movement": "Index finger traces continuous circles",
      "movementType": "circular_continuous",
      "hands": "one",
      "palmOrientation": "palm_away",
      "contactPoint": null,
      "nonManual": "mouth 'always'",
      "notes": "Continuous circular motion = ongoing/permanent"
    },
    {
      "gloss": "NEVER",
      "handshape": "B",
      "handshapeDescription": "Flat hand",
      "location": "neutral space",
      "movement": "Flat hand waves sharply side-to-side",
      "movementType": "path_sideways_repeated",
      "hands": "one",
      "palmOrientation": "palm_away",
      "contactPoint": null,
      "nonManual": "head shake, negative expression, mouth 'never'",
      "notes": "Head shake is grammatically essential for negation"
    },
    {
      "gloss": "SOMETIMES",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "neutral space",
      "movement": "Index finger taps forward slowly with pauses (intermittent)",
      "movementType": "path_forward_intermittent",
      "hands": "one",
      "palmOrientation": "palm_up",
      "contactPoint": null,
      "nonManual": "mouth 'sometimes', uncertain expression",
      "notes": null
    },
    {
      "gloss": "OFTEN",
      "handshape": "B-bent",
      "handshapeDescription": "Bent hand",
      "location": "non-dominant palm",
      "movement": "Bent hand taps non-dominant palm repeatedly",
      "movementType": "contact_tap_repeated",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": "hand on palm",
      "nonManual": "mouth 'often'",
      "notes": "Repeated tapping = frequency"
    },
    {
      "gloss": "SOON",
      "handshape": "G",
      "handshapeDescription": "Index finger or flat hand",
      "location": "neutral space, close to body",
      "movement": "Short forward movement (near future)",
      "movementType": "path_forward_short",
      "hands": "one",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'soon'",
      "notes": "Short forward movement = near future"
    },
    {
      "gloss": "EARLY",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "non-dominant palm/wrist area",
      "movement": "Index finger taps near wrist on non-dominant hand (beginning of timeline)",
      "movementType": "contact_tap",
      "hands": "two",
      "palmOrientation": "non-dominant palm_up",
      "contactPoint": "finger on wrist",
      "nonManual": "mouth 'early'",
      "notes": "Near wrist = early in timeframe"
    },
    {
      "gloss": "LATE",
      "handshape": "B or L",
      "handshapeDescription": "Flat hand or L-shape",
      "location": "neutral space",
      "movement": "Hand drops downward with slight twist",
      "movementType": "path_down",
      "hands": "one",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'late', apologetic expression",
      "notes": null
    },
    {
      "gloss": "CLOCK",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "non-dominant wrist",
      "movement": "Index finger taps wrist (where watch would be)",
      "movementType": "contact_tap",
      "hands": "two",
      "palmOrientation": "non-dominant palm_down, dominant palm_down",
      "contactPoint": "finger taps wrist",
      "nonManual": "mouth 'clock' or 'time'",
      "notes": "Same as TIME in many contexts"
    },
    {
      "gloss": "HOUR",
      "handshape": "G",
      "handshapeDescription": "Index finger extended",
      "location": "non-dominant palm",
      "movement": "Index finger makes one full circle on non-dominant palm (clock hand going around)",
      "movementType": "circular",
      "hands": "two",
      "palmOrientation": "non-dominant palm_toward (like clock face)",
      "contactPoint": "finger circles on palm",
      "nonManual": "mouth 'hour'",
      "notes": "Iconic: clock hand making one revolution"
    },
    {
      "gloss": "MINUTE",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "non-dominant palm",
      "movement": "Small quick tick movement of index finger on palm",
      "movementType": "path_short",
      "hands": "two",
      "palmOrientation": "non-dominant palm_toward",
      "contactPoint": "finger on palm",
      "nonManual": "mouth 'minute'",
      "notes": "Smaller movement than HOUR"
    }
  ]
}
