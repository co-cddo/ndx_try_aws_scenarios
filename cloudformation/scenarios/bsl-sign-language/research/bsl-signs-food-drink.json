{
  "_meta": {
    "category": "Food & Drink",
    "description": "BSL signs for food, drink and meal-related vocabulary",
    "sources": ["Access BSL", "BSL SignBank", "Baby BSL", "Warwickshire County Council BSL resource", "BrightBSL"]
  },
  "signs": [
    {
      "gloss": "EAT",
      "handshape": "O-flat",
      "handshapeDescription": "Fingertips pinched together (flat O)",
      "location": "mouth",
      "movement": "Pinched fingertips tap mouth repeatedly",
      "movementType": "contact_tap_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "fingertips to lips",
      "nonManual": "mouth opens slightly with each tap",
      "notes": "Iconic: putting food in mouth"
    },
    {
      "gloss": "DRINK",
      "handshape": "C",
      "handshapeDescription": "C-shape hand (as if holding a cup)",
      "location": "mouth",
      "movement": "C-hand tilts toward mouth as if drinking from cup",
      "movementType": "local_hand_rotation_twist",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": "thumb-side near lips",
      "nonManual": "mouth 'drink'",
      "notes": "Iconic: drinking from cup"
    },
    {
      "gloss": "WATER",
      "handshape": "B",
      "handshapeDescription": "Flat hand with fingers together",
      "location": "chin/mouth area",
      "movement": "Fingertips tap chin twice",
      "movementType": "contact_tap_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "fingertips to chin",
      "nonManual": "mouth 'water'",
      "notes": "Regional variants exist"
    },
    {
      "gloss": "TEA",
      "handshape": "O + G",
      "handshapeDescription": "Non-dominant C-hand (holding cup), dominant hand with pinch/stir",
      "location": "neutral space",
      "movement": "Dominant hand mimics stirring inside the non-dominant C-hand cup",
      "movementType": "circular",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": "stirring finger inside C-hand",
      "nonManual": "mouth 'tea'",
      "notes": "Iconic: stirring tea in a cup"
    },
    {
      "gloss": "COFFEE",
      "handshape": "C",
      "handshapeDescription": "C-shape hand",
      "location": "neutral space then mouth",
      "movement": "C-hand lifts up and tips toward face as if drinking from cup",
      "movementType": "path_up_toward",
      "hands": "one",
      "palmOrientation": "palm_left",
      "contactPoint": null,
      "nonManual": "mouth 'coffee'",
      "notes": "Similar to DRINK but with specific mouthing"
    },
    {
      "gloss": "MILK",
      "handshape": "S",
      "handshapeDescription": "Fist",
      "location": "neutral space",
      "movement": "Fist pumps open and closed (squeezing motion, like milking)",
      "movementType": "local_finger_flex",
      "hands": "one",
      "palmOrientation": "palm_inward",
      "contactPoint": null,
      "nonManual": "mouth 'milk'",
      "notes": "Iconic: milking a cow"
    },
    {
      "gloss": "JUICE",
      "handshape": "C",
      "handshapeDescription": "C-hand squeezing",
      "location": "neutral space",
      "movement": "C-hand squeezes (fingers close toward thumb) then tips toward mouth",
      "movementType": "local_finger_close",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": null,
      "nonManual": "mouth 'juice'",
      "notes": "Iconic: squeezing fruit"
    },
    {
      "gloss": "BEER",
      "handshape": "A",
      "handshapeDescription": "Fist gripping (as if holding a pint glass)",
      "location": "neutral space near mouth",
      "movement": "Fist tilts toward mouth as if drinking from pint",
      "movementType": "local_hand_rotation_twist",
      "hands": "one",
      "palmOrientation": "palm_inward",
      "contactPoint": null,
      "nonManual": "mouth 'beer'",
      "notes": "Larger grip than TEA/COFFEE to show pint glass"
    },
    {
      "gloss": "WINE",
      "handshape": "G-closed",
      "handshapeDescription": "Index-thumb pinch or W-fingerspell",
      "location": "cheek",
      "movement": "Small circles at cheek (rosy cheeks from wine)",
      "movementType": "circular",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "fingertip near cheek",
      "nonManual": "mouth 'wine'",
      "notes": "Iconic: rosy cheek from drinking wine"
    },
    {
      "gloss": "BREAD",
      "handshape": "O-flat",
      "handshapeDescription": "Pinched fingertips",
      "location": "mouth",
      "movement": "Fingertips held together tap to mouth and away",
      "movementType": "contact_tap_repeated",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "fingertips to mouth",
      "nonManual": "mouth 'bread'",
      "notes": "Similar to EAT; distinguished by mouthing"
    },
    {
      "gloss": "BUTTER",
      "handshape": "N",
      "handshapeDescription": "Index and middle fingers extended together",
      "location": "non-dominant palm",
      "movement": "Dominant fingers brush across non-dominant palm repeatedly (spreading butter)",
      "movementType": "path_sideways_repeated",
      "hands": "two",
      "palmOrientation": "dominant palm_down, non-dominant palm_up",
      "contactPoint": "fingers on palm",
      "nonManual": "mouth 'butter'",
      "notes": "Iconic: spreading butter on bread"
    },
    {
      "gloss": "CHEESE",
      "handshape": "B",
      "handshapeDescription": "Flat hands",
      "location": "neutral space",
      "movement": "Palms press together and twist/rotate against each other",
      "movementType": "local_hand_rotation_twist",
      "hands": "two",
      "palmOrientation": "palms facing each other",
      "contactPoint": "palms together",
      "nonManual": "mouth 'cheese'",
      "notes": "Iconic: pressing/moulding cheese"
    },
    {
      "gloss": "EGG",
      "handshape": "N",
      "handshapeDescription": "Index and middle fingers extended",
      "location": "non-dominant hand",
      "movement": "Dominant fingers tap/crack against non-dominant index finger",
      "movementType": "contact_tap",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": "fingers tap",
      "nonManual": "mouth 'egg'",
      "notes": "Iconic: cracking an egg; regional variations exist"
    },
    {
      "gloss": "MEAT",
      "handshape": "G-closed + B",
      "handshapeDescription": "Dominant hand pinches, non-dominant flat hand",
      "location": "non-dominant hand",
      "movement": "Dominant hand pinches fleshy part of non-dominant hand between thumb and index",
      "movementType": "contact_pinch",
      "hands": "two",
      "palmOrientation": "non-dominant palm_down",
      "contactPoint": "pinch on back of hand",
      "nonManual": "mouth 'meat'",
      "notes": "Iconic: pinching flesh"
    },
    {
      "gloss": "CHICKEN",
      "handshape": "G-closed",
      "handshapeDescription": "Index-thumb pinch (beak shape)",
      "location": "mouth",
      "movement": "Pinch opens and closes at mouth (pecking motion)",
      "movementType": "local_finger_flex",
      "hands": "one",
      "palmOrientation": "palm_down",
      "contactPoint": "near mouth",
      "nonManual": "mouth 'chicken'",
      "notes": "Iconic: chicken pecking"
    },
    {
      "gloss": "FISH",
      "handshape": "B",
      "handshapeDescription": "Flat hand",
      "location": "neutral space",
      "movement": "Flat hand held horizontally, wiggles forward (like fish swimming)",
      "movementType": "path_forward_wiggle",
      "hands": "one",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'fish'",
      "notes": "Iconic: fish swimming through water"
    },
    {
      "gloss": "RICE",
      "handshape": "O-flat",
      "handshapeDescription": "Pinched fingertips",
      "location": "neutral space",
      "movement": "Fingers sprinkle/release (as if dropping grains of rice)",
      "movementType": "local_finger_open",
      "hands": "one",
      "palmOrientation": "palm_down",
      "contactPoint": null,
      "nonManual": "mouth 'rice'",
      "notes": null
    },
    {
      "gloss": "SOUP",
      "handshape": "N",
      "handshapeDescription": "Index and middle fingers extended",
      "location": "non-dominant palm (bowl) then mouth",
      "movement": "Scoop from non-dominant palm toward mouth",
      "movementType": "path_toward_repeated",
      "hands": "two",
