{
  "_meta": {
    "category": "Emotions & Mental States",
    "description": "BSL signs for emotions, feelings, and mental states",
    "sources": ["Commanding Hands", "BSL SignBank", "Access BSL"],
    "notes": "Facial expression is CRITICAL for emotion signs - the non-manual component often carries most of the meaning"
  },
  "signs": [
    {"gloss": "HAPPY", "handshape": "B", "location": "chest", "movement": "Flat hands brush upward on chest", "movementType": "path_up_repeated", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "big smile, bright eyes", "notes": "Upward on chest = positive feeling rising"},
    {"gloss": "SAD", "handshape": "B", "location": "face", "movement": "Flat hand moves slowly downward past face", "movementType": "path_down", "hands": "one", "palmOrientation": "palm_toward", "nonManual": "drooped mouth, sad eyes, shoulders droop"},
    {"gloss": "ANGRY", "handshape": "5-claw", "location": "chest/stomach rising", "movement": "Claw hands rise tensely from stomach to chest", "movementType": "path_up_tense", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "furrowed brow, tight lips, tense face"},
    {"gloss": "WORRIED", "handshape": "5", "location": "neutral space, in front of body", "movement": "Open hands alternate circling (churning worry)", "movementType": "circular_alternating", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "worried expression, furrowed brow"},
    {"gloss": "NERVOUS", "handshape": "5", "location": "neutral space", "movement": "Open hands shake/tremble", "movementType": "local_shake", "hands": "two", "palmOrientation": "palm_down", "nonManual": "anxious expression, tight lips"},
    {"gloss": "EXCITED", "handshape": "5", "location": "chest", "movement": "Open hands brush alternately upward on chest rapidly (excitement bubbling up)", "movementType": "path_up_alternating_fast", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "wide eyes, big smile, animated expression"},
    {"gloss": "BORED", "handshape": "G", "location": "nose", "movement": "Index finger rests on side of nose, slight twist", "movementType": "local_twist", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "finger on nose", "nonManual": "bored expression, flat affect"},
    {"gloss": "CONFUSED", "handshape": "5-claw", "location": "forehead", "movement": "Claw hands at forehead circle/interlock (tangled thoughts)", "movementType": "circular", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "puzzled expression, furrowed brow"},
    {"gloss": "SURPRISED", "handshape": "G-closed to 5", "location": "eyes", "movement": "Pinch handshapes at eyes spring open to spread hands (eyes popping open)", "movementType": "local_finger_open", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "wide eyes, raised eyebrows, open mouth"},
    {"gloss": "SHOCKED", "handshape": "5-claw", "location": "face", "movement": "Claw hands snap open near face, body jerks back", "movementType": "local_finger_open_sharp", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "wide eyes, mouth open, body recoils"},
    {"gloss": "EMBARRASSED", "handshape": "B-open", "location": "cheeks", "movement": "Open hands sweep up cheeks (blushing)", "movementType": "path_up", "hands": "two", "palmOrientation": "palm_toward", "contactPoint": "hands on cheeks", "nonManual": "blushing expression, look down"},
    {"gloss": "PROUD", "handshape": "Thumb", "location": "chest", "movement": "Thumb(s) up on chest, chest puffs out", "movementType": "contact_hold", "hands": "one or two", "palmOrientation": "palm_toward", "contactPoint": "thumb on chest", "nonManual": "chest puffed out, chin up, proud expression"},
    {"gloss": "JEALOUS", "handshape": "I or G-bent", "location": "chin/mouth corner", "movement": "Little finger or bent finger hooks at corner of mouth and pulls", "movementType": "path_sideways", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "finger at mouth corner", "nonManual": "envious expression"},
    {"gloss": "LONELY", "handshape": "G", "location": "chin/mouth", "movement": "Index finger at lips, slight downward movement", "movementType": "path_down", "hands": "one", "palmOrientation": "palm_left", "contactPoint": "finger on lips", "nonManual": "lonely sad expression"},
    {"gloss": "LOVE", "handshape": "B", "location": "chest", "movement": "Arms cross over chest, hugging heart", "movementType": "contact_hold", "hands": "two", "palmOrientation": "palm_toward", "contactPoint": "arms crossed on chest", "nonManual": "warm expression"},
    {"gloss": "HATE", "handshape": "5", "location": "chest then forward", "movement": "Hand flicks away from chest forcefully", "movementType": "path_away_sharp", "hands": "one", "palmOrientation": "palm_down", "nonManual": "disgusted face, furrowed brow"},
    {"gloss": "FEAR", "handshape": "5", "location": "chest", "movement": "Open hands tremble/shake at chest, body shrinks back", "movementType": "local_shake", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "wide fearful eyes, body tenses"},
    {"gloss": "HOPE", "handshape": "R or V-crossed", "location": "neutral space", "movement": "Crossed fingers held up (fingers crossed)", "movementType": "hold", "hands": "one", "palmOrientation": "palm_away", "nonManual": "hopeful expression, looking up"},
    {"gloss": "STRESS", "handshape": "5-claw", "location": "head/temples", "movement": "Claw hands at sides of head, squeezing motion", "movementType": "local_finger_close", "hands": "two", "palmOrientation": "palm_toward", "nonManual": "stressed expression, tense face"},
    {"gloss": "CALM", "handshape": "B", "location": "neutral space", "movement": "Both flat hands slowly press downward (calming motion)", "movementType": "path_down_slow", "hands": "two", "palmOrientation": "palm_down", "nonManual": "relaxed expression, slow exhale"},
    {"gloss": "PATIENT", "handshape": "Thumb", "location": "chin", "movement": "Thumb slowly strokes down chin", "movementType": "path_down_slow", "hands": "one", "palmOrientation": "palm_left", "contactPoint": "thumb on chin", "nonManual": "patient expression, 'mm' mouth"},
    {"gloss": "FRUSTRATED", "handshape": "B", "location": "chin/face", "movement": "Flat hand strikes up against chin", "movementType": "path_up_sharp", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "back of hand hits chin", "nonManual": "frustrated expression, exasperated"},
    {"gloss": "DISAPPOINTED", "handshape": "G", "location": "nose/chin", "movement": "Index finger on chin slides downward", "movementType": "path_down", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "finger on chin moving down", "nonManual": "shoulders droop, disappointed face"},
    {"gloss": "GRATEFUL", "handshape": "B", "location": "chin then forward", "movement": "Similar to THANK-YOU but with more emphasis, repeated", "movementType": "path_forward_repeated", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "fingertips from chin", "nonManual": "sincere grateful expression, nod"},
    {"gloss": "CONFIDENT", "handshape": "A or Thumb", "location": "chest", "movement": "Fists/thumbs placed firmly on chest, body upright", "movementType": "contact_hold_firm", "hands": "two", "palmOrientation": "palm_toward", "contactPoint": "on chest", "nonManual": "upright posture, chin up, assured expression"},
    {"gloss": "SHY", "handshape": "B", "location": "cheek", "movement": "Hand covers cheek, head turns slightly away", "movementType": "contact_hold", "hands": "one", "palmOrientation": "palm_toward", "contactPoint": "hand on cheek", "nonManual": "head turns away, embarrassed look, look down"},
    {"gloss": "BRAVE", "handshape": "A", "location": "chest", "movement": "Fists pulled out from chest firmly (drawing courage)", "movementType": "path_forward_firm", "hands": "two", "palmOrientation": "palm_toward", "contactPoint": "start on chest", "nonManual": "determined expression, chest out"}
  ]
}
