  "numbers": [
    {"gloss": "1", "handshape": "G", "description": "Index finger raised, palm toward signer", "palmOrientation": "palm_toward", "notes": "Universal across UK"},
    {"gloss": "2", "handshape": "V-closed", "description": "Index and middle fingers raised together, palm toward signer", "palmOrientation": "palm_toward", "notes": "Universal across UK"},
    {"gloss": "3", "handshape": "W-closed", "description": "Index, middle, ring fingers raised, palm toward signer", "palmOrientation": "palm_toward", "notes": "Universal across UK"},
    {"gloss": "4", "handshape": "4", "description": "All four fingers raised (no thumb), palm toward signer", "palmOrientation": "palm_toward", "notes": "Universal across UK"},
    {"gloss": "5", "handshape": "5", "description": "All five digits spread, palm toward signer", "palmOrientation": "palm_toward", "notes": "Universal across UK"},
    {"gloss": "6", "handshape": "Thumb (south) / I (north)", "description": "Southern: thumb extended from fist. Northern: little finger extended", "palmOrientation": "palm_toward", "notes": "FIRST major regional split"},
    {"gloss": "7", "handshape": "Thumb+G (south) / I+ring (north)", "description": "Southern: thumb + index. Northern: little + ring finger", "palmOrientation": "palm_toward", "notes": "Regional variant continues"},
    {"gloss": "8", "handshape": "Thumb+V (south)", "description": "Southern: thumb + index + middle. Northern: little + ring + middle", "palmOrientation": "palm_toward", "notes": "Regional variant continues"},
    {"gloss": "9", "handshape": "Thumb+W (south)", "description": "Southern: thumb + three fingers. Northern: all except thumb. Southern 9 requires bending little finger", "palmOrientation": "palm_toward", "notes": "Famously difficult handshape"},
    {"gloss": "10", "handshape": "5+5", "description": "Both hands show 5 (two fives), or fists with thumbs flicked out", "palmOrientation": "palm_toward", "notes": "Both hands used"},
    {"gloss": "11", "handshape": "G+G", "description": "Index fingers of both hands raised, flicked twice", "palmOrientation": "palm_toward", "notes": "Doubled single digit"},
    {"gloss": "12", "handshape": "G+V", "description": "One hand shows 1, other shows 2", "palmOrientation": "palm_toward", "notes": null},
    {"gloss": "13", "handshape": "G+W", "description": "One hand shows 1, other shows 3", "palmOrientation": "palm_toward", "notes": null},
    {"gloss": "14", "handshape": "G+4", "description": "One hand shows 1, other shows 4", "palmOrientation": "palm_toward", "notes": null},
    {"gloss": "15", "handshape": "G+5", "description": "One hand shows 1, other shows 5", "palmOrientation": "palm_toward", "notes": null},
    {"gloss": "16-19", "handshape": "G+6-9", "description": "One hand shows 1, other shows 6-9 (using regional variant)", "palmOrientation": "palm_toward", "notes": "Regional system continues"},
    {"gloss": "20", "handshape": "V+fist-squeeze", "description": "V-hand (2) with squeezing/pinching motion (zero), or two fists with thumbs", "palmOrientation": "palm_toward", "notes": "Varies regionally"},
    {"gloss": "100", "handshape": "G + C", "description": "Show 1 then C-hand, while mouthing 'one hundred'", "palmOrientation": "varies", "notes": "Mouthing is critical"},
    {"gloss": "1000", "handshape": "G + comma", "description": "Index finger curves downward drawing a comma shape while mouthing 'one thousand'", "palmOrientation": "varies", "notes": "Comma gesture represents thousands separator"},
    {"gloss": "FIRST", "handshape": "G", "description": "Index finger raised, moves forward/down decisively", "palmOrientation": "palm_toward", "notes": "Ordinal: emphatic single finger"},
    {"gloss": "SECOND", "handshape": "V", "description": "V-hand (two), may move forward", "palmOrientation": "palm_toward", "notes": null},
    {"gloss": "THIRD", "handshape": "W", "description": "Three fingers, may move forward", "palmOrientation": "palm_toward", "notes": null},
    {"gloss": "HOW-MANY", "handshape": "5-claw to 5", "description": "Claw hands open questioningly, palms up", "palmOrientation": "palm_up", "nonManual": "furrowed brows (wh-question), mouth 'how many'", "notes": "WH-question requires furrowed brows"}
  ]
