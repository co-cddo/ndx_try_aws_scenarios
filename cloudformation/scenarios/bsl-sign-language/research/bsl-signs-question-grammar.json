{
  "_meta": {
    "category": "Question Words & Grammar",
    "description": "BSL signs for question words, conjunctions, and grammatical function words",
    "sources": ["BSL SignBank", "Access BSL", "University of Surrey BSL", "Evergreen Life", "BSL Corpus Project"],
    "notes": [
      "WH-questions (what, who, where, when, why, how) require FURROWED BROWS",
      "Yes/No questions require RAISED EYEBROWS and forward lean",
      "Negation can be achieved by HEAD SHAKE alone or combined with sign",
      "BSL grammar uses Topic-Comment structure, not English SVO word order"
    ]
  },
  "signs": [
    {
      "gloss": "WHAT",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "neutral space, chest level",
      "movement": "Index finger makes short side-to-side movements",
      "movementType": "path_sideways_short_repeated",
      "hands": "one",
      "palmOrientation": "palm_up",
      "nonManual": "FURROWED BROWS (required for wh-question), forward head tilt, mouth 'what'",
      "notes": "Variant: L-handshape at chin, bend index down"
    },
    {
      "gloss": "WHO",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "neutral space",
      "movement": "Index finger held up, makes small circles",
      "movementType": "circular_small",
      "hands": "one",
      "palmOrientation": "palm_away",
      "nonManual": "FURROWED BROWS, mouth 'who'"
    },
    {
      "gloss": "WHERE",
      "handshape": "G-bent to G",
      "handshapeDescription": "Bent index straightening",
      "location": "neutral space",
      "movement": "Index finger draws question mark shape in air, ending in point",
      "movementType": "path_question_mark",
      "hands": "one",
      "palmOrientation": "palm_away",
      "nonManual": "FURROWED BROWS, shrugged shoulders, mouth 'where'"
    },
    {
      "gloss": "WHEN",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "non-dominant wrist (time reference)",
      "movement": "Index finger circles near non-dominant wrist then points down (question)",
      "movementType": "circular_then_point",
      "hands": "two",
      "palmOrientation": "varies",
      "contactPoint": "near wrist",
      "nonManual": "FURROWED BROWS, mouth 'when'"
    },
    {
      "gloss": "WHY",
      "handshape": "G or B",
      "handshapeDescription": "Index finger or flat hand",
      "location": "forehead/temple",
      "movement": "Finger/hand touches forehead then moves away with questioning twist",
      "movementType": "contact_then_twist",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "finger on forehead",
      "nonManual": "FURROWED BROWS, head tilts forward, mouth 'why'"
    },
    {
      "gloss": "HOW",
      "handshape": "B-bent",
      "handshapeDescription": "Bent hands, fingertips together",
      "location": "neutral space",
      "movement": "Bent hands with fingertips together twist/roll open",
      "movementType": "local_hand_rotation_twist",
      "hands": "two",
      "palmOrientation": "palm_down then palm_up (rolling)",
      "contactPoint": "fingertips start together",
      "nonManual": "FURROWED BROWS, mouth 'how'"
    },
    {
      "gloss": "WHICH",
      "handshape": "Thumb",
      "handshapeDescription": "Thumbs up alternating",
      "location": "neutral space",
      "movement": "Both thumbs-up hands alternate up and down (weighing options)",
      "movementType": "alternating_up_down",
      "hands": "two",
      "palmOrientation": "palm_toward each other",
      "nonManual": "FURROWED BROWS, mouth 'which'"
    },
    {
      "gloss": "HOW-MUCH",
      "handshape": "5-claw",
      "handshapeDescription": "Claw hands, palms up",
      "location": "neutral space",
      "movement": "Claw hands held palms up, shake slightly",
      "movementType": "local_shake",
      "hands": "two",
      "palmOrientation": "palm_up",
      "nonManual": "FURROWED BROWS, mouth 'how much'"
    },
    {
      "gloss": "HOW-MANY",
      "handshape": "A to 5",
      "handshapeDescription": "Fists opening to spread hands",
      "location": "neutral space",
      "movement": "Fists open quickly to spread five-fingers (burst open)",
      "movementType": "local_finger_open",
      "hands": "two",
      "palmOrientation": "palm_up",
      "nonManual": "FURROWED BROWS, mouth 'how many'"
    },
    {
      "gloss": "YES",
      "handshape": "A",
      "handshapeDescription": "Fist",
      "location": "neutral space",
      "movement": "Fist nods forward at wrist",
      "movementType": "local_wrist_nod",
      "hands": "one",
      "palmOrientation": "palm_away",
      "nonManual": "head nod"
    },
    {
      "gloss": "NO",
      "handshape": "G+N to G-closed",
      "handshapeDescription": "Index and middle fingers close onto thumb",
      "location": "neutral space",
      "movement": "Fingers snap closed onto thumb",
      "movementType": "local_finger_close",
      "hands": "one",
      "palmOrientation": "palm_away",
      "nonManual": "head shake"
    },
    {
      "gloss": "NOT",
      "handshape": "varies",
      "handshapeDescription": "Head shake is primary marker",
      "location": "N/A",
      "movement": "Head shake performed simultaneously with any sign to negate it",
      "movementType": "non_manual",
      "hands": "N/A",
      "palmOrientation": "N/A",
      "nonManual": "HEAD SHAKE is the primary negation marker in BSL",
      "notes": "Head shake can negate ANY sign without needing a separate NOT sign"
    },
    {
      "gloss": "MAYBE",
      "handshape": "B",
      "handshapeDescription": "Flat hands, palms up",
      "location": "neutral space",
      "movement": "Both flat hands palms up, rock alternately up and down (weighing)",
      "movementType": "alternating_up_down",
      "hands": "two",
      "palmOrientation": "palm_up",
      "nonManual": "uncertain expression, lips pressed, head tilts, mouth 'maybe'"
    },
    {
      "gloss": "IF",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "neutral space",
      "movement": "Index finger pointed up, slight forward movement",
      "movementType": "path_forward_slight",
      "hands": "one",
      "palmOrientation": "palm_left",
      "nonManual": "raised eyebrows, head tilt to side, conditional expression",
      "notes": "The raised eyebrows mark the conditional clause"
    },
    {
      "gloss": "BECAUSE",
      "handshape": "G",
      "handshapeDescription": "Index finger at forehead",
      "location": "forehead",
      "movement": "Index finger touches forehead then moves forward/down",
      "movementType": "path_forward_down",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "contactPoint": "finger on forehead",
      "nonManual": "mouth 'because'",
      "notes": "Links cause and effect"
    },
    {
      "gloss": "BUT",
      "handshape": "G",
      "handshapeDescription": "Index fingers",
      "location": "neutral space",
      "movement": "Both index fingers cross then pull apart sharply (contrasting)",
      "movementType": "path_cross_then_apart",
      "hands": "two",
      "palmOrientation": "palm_toward",
      "contactPoint": "fingers cross",
      "nonManual": "mouth 'but'"
    },
    {
      "gloss": "AND",
      "handshape": "5 to O-flat",
      "handshapeDescription": "Open hand closing to pinch",
      "location": "neutral space",
      "movement": "Open hand pulls sideways and closes to pinch (gathering/adding)",
      "movementType": "path_sideways_close",
      "hands": "one",
      "palmOrientation": "palm_toward",
      "nonManual": "mouth 'and'",
      "notes": "Also: items can simply be listed spatially without an explicit AND sign"
    },
    {
      "gloss": "OR",
      "handshape": "G",
      "handshapeDescription": "Index fingers pointing at alternatives",
      "location": "neutral space, two locations",
      "movement": "Index finger points to one location then the other (two choices)",
      "movementType": "path_alternating_point",
      "hands": "one",
      "palmOrientation": "palm_down",
      "nonManual": "mouth 'or', raised eyebrows"
    },
    {
      "gloss": "ALSO",
      "handshape": "G",
      "handshapeDescription": "Index fingers",
      "location": "neutral space",
      "movement": "Index fingers tap together (adding together)",
      "movementType": "contact_tap",
      "hands": "two",
      "palmOrientation": "palm_down",
      "contactPoint": "fingertips tap",
      "nonManual": "mouth 'also'"
    },
    {
      "gloss": "VERY",
      "handshape": "B-open",
      "handshapeDescription": "Open hands",
      "location": "neutral space",
      "movement": "Both hands clap together sharply or sign is intensified",
      "movementType": "contact_sharp",
      "hands": "two",
      "palmOrientation": "palms together",
      "nonManual": "puffed cheeks, wider eyes, emphatic expression",
      "notes": "Often expressed through manner modification (bigger, slower, more tense movement) rather than a separate sign"
    },
    {
      "gloss": "ALL",
      "handshape": "B",
      "handshapeDescription": "Flat hand sweeping",
      "location": "neutral space",
      "movement": "Flat hand sweeps in large circle (encompassing everything)",
      "movementType": "circular_wide",
      "hands": "one",
      "palmOrientation": "palm_down",
      "nonManual": "mouth 'all'"
    },
    {
      "gloss": "SOME",
      "handshape": "B",
      "handshapeDescription": "Flat hand",
      "location": "non-dominant palm",
      "movement": "Dominant flat hand scoops across non-dominant palm (taking some)",
      "movementType": "path_across_scoop",
      "hands": "two",
      "palmOrientation": "non-dominant palm_up, dominant edge",
      "nonManual": "mouth 'some'"
    },
    {
      "gloss": "NONE",
      "handshape": "O",
      "handshapeDescription": "O-hand (zero)",
      "location": "neutral space",
      "movement": "O-hand moves forward",
      "movementType": "path_forward",
      "hands": "one",
      "palmOrientation": "palm_away",
      "nonManual": "head shake, mouth 'none'"
    },
    {
      "gloss": "THIS",
      "handshape": "G",
      "handshapeDescription": "Index finger pointing down",
      "location": "neutral space, near body",
      "movement": "Index finger points down near body (here/this)",
      "movementType": "contact_point",
      "hands": "one",
      "palmOrientation": "palm_down",
      "nonManual": "mouth 'this'"
    },
    {
      "gloss": "THAT",
      "handshape": "G",
      "handshapeDescription": "Index finger pointing away",
      "location": "neutral space, forward/away",
      "movement": "Index finger points forward/away from body",
      "movementType": "contact_point",
      "hands": "one",
      "palmOrientation": "palm_down",
      "nonManual": "mouth 'that'"
    },
    {
      "gloss": "HERE",
      "handshape": "G",
      "handshapeDescription": "Index finger pointing down",
      "location": "directly below, close to body",
      "movement": "Index finger points straight down (this location)",
      "movementType": "contact_point_down",
      "hands": "one",
      "palmOrientation": "palm_down",
      "nonManual": "mouth 'here'"
    },
    {
      "gloss": "THERE",
      "handshape": "G",
      "handshapeDescription": "Index finger pointing away",
      "location": "neutral space, at a distance",
      "movement": "Index finger points to a distant location",
      "movementType": "contact_point_away",
      "hands": "one",
      "palmOrientation": "palm_down",
      "nonManual": "eye gaze follows pointing, mouth 'there'"
    },
    {
      "gloss": "CAN",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "eye level",
      "movement": "Index finger moves downward from eye level to stomach level",
      "movementType": "path_down",
      "hands": "one",
      "palmOrientation": "palm_away",
      "nonManual": "positive expression, mouth 'can'",
      "notes": "Raised eyebrows if asking 'CAN you...?'"
    },
    {
      "gloss": "MUST",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "neutral space",
      "movement": "Index finger points forward and moves down firmly (obligatory)",
      "movementType": "path_down_firm",
      "hands": "one",
      "palmOrientation": "palm_down",
      "nonManual": "firm serious expression, mouth 'must'"
    },
    {
      "gloss": "SHOULD",
      "handshape": "G",
      "handshapeDescription": "Index finger",
      "location": "neutral space",
      "movement": "Index finger moves forward with slight downward motion (less forceful than MUST)",
      "movementType": "path_forward_down",
      "hands": "one",
      "palmOrientation": "palm_away",
      "nonManual": "advisory expression, mouth 'should'"
    },
    {
      "gloss": "WILL",
      "handshape": "B",
      "handshapeDescription": "Flat hand",
      "location": "neutral space, near cheek",
      "movement": "Hand moves forward (future timeline direction)",
      "movementType": "path_forward",
      "hands": "one",
      "palmOrientation": "palm_left",
      "nonManual": "mouth 'will'",
      "notes": "Forward movement = future intention"
    }
  ]
}
