{
  "compilerOptions": {
    "target": "ES2018",
    "module": "commonjs",
    "lib": ["es2018"],
    "declaration": true,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false,
    "inlineSourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "typeRoots": [
      "./node_modules/@types",
      "../.upstream/infrastructure/node_modules/@types"
    ],
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "*": [
        "./node_modules/*",
        "../.upstream/infrastructure/node_modules/*"
      ]
    },
    "rootDir": ".",
    "outDir": "./dist"
  },
  "include": [
    "bin/**/*.ts",
    "lib/**/*.ts",
    "../.upstream/infrastructure/lib/**/*.ts"
  ],
  "exclude": ["node_modules", "cdk.out", "dist"]
}
